---
// src/layouts/Layout.astro
export interface Props {
  title:       string;
  description: string;
  image?:      string;
  type?:       string;
  noindex?:    boolean;
}

const {
  title,
  description,
  image    = "/og-default.jpg",
  type     = "website",
  noindex  = false,
} = Astro.props;

const siteUrl     = "https://bigpianosmallpiano.pages.dev";
const canonicalURL = new URL(Astro.url.pathname, siteUrl).href;
const fullTitle    = title.includes("Big Piano") ? title : `${title} | Big Piano Small Piano`;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>{fullTitle}</title>
  <meta name="description"        content={description} />
  <link rel="canonical"           href={canonicalURL} />
  {noindex && <meta name="robots" content="noindex, follow" />}

  <meta property="og:type"        content={type} />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:title"       content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={image.startsWith("http") ? image : `${siteUrl}${image}`} />
  <meta property="og:site_name"   content="Big Piano Small Piano" />

  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={image.startsWith("http") ? image : `${siteUrl}${image}`} />

  <meta name="theme-color" content="#0D0D0D" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500&family=DM+Mono&display=swap"
    rel="stylesheet"
  />

  <link rel="preconnect" href="https://www.youtube.com" />
  <link rel="dns-prefetch" href="https://i.ytimg.com" />

  <style>
    :root { color-scheme: dark; }
    html  { background-color: #0D0D0D; }
    body  { font-family: 'DM Sans', system-ui, sans-serif; }

    .gold-rule {
      border: none;
      height: 1px;
      background: linear-gradient(90deg, transparent, #C9A84C 40%, #C9A84C 60%, transparent);
    }
    .reveal { opacity: 0; transform: translateY(16px); transition: opacity 0.5s ease, transform 0.5s ease; }
    .reveal.visible { opacity: 1; transform: none; }

    /* Mobile nav drawer */
    #mobile-drawer {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 100;
    }
    #mobile-drawer.open {
      display: block;
    }
    #drawer-backdrop {
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,0.7);
    }
    #drawer-panel {
      position: absolute;
      top: 0;
      right: 0;
      bottom: 0;
      width: 72vw;
      max-width: 280px;
      background: #141414;
      border-left: 1px solid #2A2A2A;
      display: flex;
      flex-direction: column;
      padding: 1.5rem;
      gap: 0.25rem;
    }
    .drawer-link {
      display: block;
      padding: 0.75rem 1rem;
      color: rgba(248,245,238,0.7);
      font-size: 0.95rem;
      border-radius: 8px;
      text-decoration: none;
      transition: background 0.15s, color 0.15s;
    }
    .drawer-link:hover, .drawer-link:active {
      background: #1C1C1C;
      color: #C9A84C;
    }
    .drawer-link.gold {
      color: #C9A84C;
    }
    .drawer-divider {
      height: 1px;
      background: #2A2A2A;
      margin: 0.5rem 0;
    }
    .drawer-close {
      align-self: flex-end;
      background: none;
      border: none;
      color: rgba(248,245,238,0.4);
      font-size: 1.5rem;
      cursor: pointer;
      padding: 0.25rem;
      margin-bottom: 0.5rem;
      line-height: 1;
    }
  </style>
</head>

<body class="bg-ebony text-ivory font-body antialiased min-h-screen flex flex-col">

  <!-- ═══════════ NAV ═══════════ -->
  <header class="sticky top-0 z-50 border-b border-surface-border bg-ebony/95 backdrop-blur-sm">
    <nav class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between gap-6">

      <!-- Wordmark -->
      <a href="/" class="flex items-center gap-2 group flex-shrink-0">
        <span class="text-gold text-xl leading-none select-none">♪</span>
        <span class="font-display font-semibold text-ivory text-base sm:text-lg tracking-wide group-hover:text-gold transition-colors duration-200">
          Big Piano <span class="text-gold">·</span> Small Piano
        </span>
      </a>

      <!-- Desktop nav links -->
      <div class="hidden sm:flex items-center gap-1 text-sm">
        <a href="/"           class="nav-link">Videos</a>
        <a href="/scores"     class="nav-link">Free Scores</a>
        <a href="/metronome"  class="nav-link">Metronome</a>
        <a href="/tuner"      class="nav-link">Tuner</a>
        <a href="/instrument" class="nav-link">Instrument</a>
        <a
          href="https://www.youtube.com/channel/UCsKtOGplqKz3uGt9XD8VexQ"
          target="_blank" rel="noopener noreferrer"
          class="nav-link text-gold hover:text-gold-light"
        >YouTube ↗</a>
      </div>

      <!-- Mobile hamburger button -->
      <button
        id="hamburger-btn"
        aria-label="Open menu"
        class="sm:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5 rounded-lg border border-surface-border hover:border-gold/40 transition-colors"
      >
        <span class="w-5 h-0.5 bg-ivory/70 rounded-full"></span>
        <span class="w-5 h-0.5 bg-ivory/70 rounded-full"></span>
        <span class="w-5 h-0.5 bg-ivory/70 rounded-full"></span>
      </button>
    </nav>
  </header>

  <!-- ═══════════ MOBILE DRAWER ═══════════ -->
  <div id="mobile-drawer" role="dialog" aria-modal="true" aria-label="Navigation menu">
    <div id="drawer-backdrop"></div>
    <div id="drawer-panel">
      <button id="drawer-close" class="drawer-close" aria-label="Close menu">✕</button>

      <a href="/"           class="drawer-link">Videos</a>
      <a href="/scores"     class="drawer-link">Free Scores</a>
      <div class="drawer-divider"></div>
      <a href="/metronome"  class="drawer-link">🎵 Metronome</a>
      <a href="/tuner"      class="drawer-link">🎸 Tuner</a>
      <a href="/instrument" class="drawer-link">🎹 Instrument</a>
      <div class="drawer-divider"></div>
      <a
        href="https://www.youtube.com/channel/UCsKtOGplqKz3uGt9XD8VexQ"
        target="_blank" rel="noopener noreferrer"
        class="drawer-link gold"
      >YouTube Channel ↗</a>
    </div>
  </div>

  <!-- ═══════════ MAIN ═══════════ -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- ═══════════ FOOTER ═══════════ -->
  <footer class="border-t border-surface-border mt-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-ivory/40">
      <p class="font-display italic text-base text-ivory/60">Big Piano Small Piano</p>
      <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
        <a href="/"           class="hover:text-gold transition-colors">Videos</a>
        <a href="/scores"     class="hover:text-gold transition-colors">Free Scores</a>
        <a href="/metronome"  class="hover:text-gold transition-colors">Metronome</a>
        <a href="/tuner"      class="hover:text-gold transition-colors">Tuner</a>
        <a href="/instrument" class="hover:text-gold transition-colors">Instrument</a>
        <a
          href="https://www.youtube.com/channel/UCsKtOGplqKz3uGt9XD8VexQ"
          target="_blank" rel="noopener noreferrer"
          class="hover:text-gold transition-colors"
        >YouTube ↗</a>
      </div>
      <p>&copy; {new Date().getFullYear()} Big Piano Small Piano</p>
    </div>
  </footer>

  <!-- ═══════════ SCRIPTS ═══════════ -->
  <script>
    // Mobile nav
    const hamburger = document.getElementById("hamburger-btn");
    const drawer    = document.getElementById("mobile-drawer");
    const backdrop  = document.getElementById("drawer-backdrop");
    const closeBtn  = document.getElementById("drawer-close");

    function openDrawer() {
      drawer.classList.add("open");
      document.body.style.overflow = "hidden";
    }
    function closeDrawer() {
      drawer.classList.remove("open");
      document.body.style.overflow = "";
    }

    hamburger.addEventListener("click", openDrawer);
    closeBtn.addEventListener("click",  closeDrawer);
    backdrop.addEventListener("click",  closeDrawer);

    // Close on nav link tap
    drawer.querySelectorAll("a").forEach(a => a.addEventListener("click", closeDrawer));

    // Close on Escape key
    document.addEventListener("keydown", e => { if (e.key === "Escape") closeDrawer(); });

    // Scroll reveal
    const observer = new IntersectionObserver(
      entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add("visible"); }),
      { threshold: 0.08 }
    );
    document.querySelectorAll(".reveal").forEach(el => observer.observe(el));
  </script>

</body>
</html>

<style>
  .nav-link {
    @apply px-3 py-1.5 rounded text-ivory/70 hover:text-ivory hover:bg-surface-raised transition-all duration-150;
  }
</style>
