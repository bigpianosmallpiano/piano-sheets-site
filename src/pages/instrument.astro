---
// src/pages/instrument.astro
import Layout from "../layouts/Layout.astro";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Free Virtual Piano & Kalimba — Big Piano Small Piano",
  "description": "Play virtual piano and kalimba in your browser. Switch instruments, change sounds, use the built-in metronome with wood/electronic/drum beats, and record your playing.",
  "url": "https://bigpianosmallpiano.pages.dev/instrument",
  "applicationCategory": "MusicApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
};
---

<Layout
  title="Free Virtual Piano & Kalimba — Big Piano Small Piano"
  description="Play virtual piano and kalimba in your browser. Switch instruments, use the built-in metronome with wood/electronic/drum beats, and record your playing."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- HERO -->
  <section class="relative overflow-hidden border-b border-surface-border">
    <div class="absolute inset-0 bg-keys-pattern opacity-50 pointer-events-none"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold to-transparent"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 py-8 text-center flex flex-col items-center gap-2">
      <p class="text-gold text-xs tracking-[0.25em] uppercase font-mono">Practice tool</p>
      <h1 class="font-display text-4xl sm:text-5xl font-semibold text-ivory leading-tight">
        Virtual <span class="italic text-gold">Instrument</span>
      </h1>
      <p class="text-ivory/50 text-sm max-w-md">Play piano or kalimba in your browser. Record your performance, practice with the metronome.</p>
    </div>
  </section>

  <!-- TOOLBAR -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-6">
    <div class="bg-surface border border-surface-border rounded-xl p-3 flex flex-wrap items-center gap-3">

      <!-- Instrument picker -->
      <div class="flex rounded-lg border border-surface-border overflow-hidden flex-shrink-0">
        <button data-inst="piano" id="btn-piano"
          class="inst-btn px-4 py-2 text-sm font-medium bg-gold text-ebony transition-all">
          🎹 Piano
        </button>
        <button data-inst="kalimba" id="btn-kalimba"
          class="inst-btn px-4 py-2 text-sm font-medium text-ivory/50 hover:text-ivory transition-all">
          ✦ Kalimba
        </button>
      </div>

      <!-- Sound type (piano only) -->
      <select id="sound-select"
        class="bg-surface-raised border border-surface-border text-ivory/80 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-gold/50">
        <option value="grand">Grand Piano</option>
        <option value="electric">Electric Piano</option>
        <option value="soft">Soft Piano</option>
        <option value="organ">Organ</option>
      </select>

      <!-- Octave (piano) -->
      <div id="octave-ctrl" class="flex items-center gap-2">
        <button id="oct-down" class="w-7 h-7 rounded border border-surface-border text-ivory/50 hover:text-gold text-sm flex items-center justify-center">−</button>
        <span class="text-ivory/60 text-xs font-mono">Oct <span id="oct-display">4</span></span>
        <button id="oct-up"   class="w-7 h-7 rounded border border-surface-border text-ivory/50 hover:text-gold text-sm flex items-center justify-center">+</button>
      </div>

      <!-- Volume -->
      <div class="flex items-center gap-2 ml-auto">
        <span class="text-ivory/30 text-xs font-mono">Vol</span>
        <input id="inst-vol" type="range" min="0" max="100" value="75"
          class="w-20 accent-gold cursor-pointer" />
      </div>
    </div>
  </div>

  <!-- PIANO KEYBOARD -->
  <div id="piano-section" class="max-w-4xl mx-auto px-4 sm:px-6 pt-4">
    <div class="bg-surface border border-surface-border rounded-xl overflow-hidden">
      <!-- Keyboard label row -->
      <div class="px-4 pt-3 pb-1 flex items-center justify-between">
        <p class="text-ivory/30 text-xs font-mono">Click keys or use keyboard (A S D F G H J K = white keys, W E T Y U = black keys)</p>
      </div>
      <!-- Piano keys -->
      <div id="piano-keys" class="relative flex h-36 sm:h-44 px-3 pb-3 select-none overflow-x-auto">
        <!-- injected by JS -->
      </div>
    </div>
  </div>

  <!-- KALIMBA -->
  <div id="kalimba-section" class="hidden max-w-4xl mx-auto px-4 sm:px-6 pt-4">
    <div class="bg-surface border border-surface-border rounded-xl p-6">
      <p class="text-ivory/30 text-xs font-mono text-center mb-5">Click tines or use number keys 1–9 then Q W E R T Y U</p>
      <!-- Kalimba tines -->
      <div id="kalimba-tines" class="flex items-end justify-center gap-1.5 h-40"></div>
      <!-- Note labels below tines -->
      <div id="kalimba-labels" class="flex items-center justify-center gap-1.5 mt-2"></div>
    </div>
  </div>

  <!-- METRONOME + RECORD ROW -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-4 pb-8">
    <div class="bg-surface border border-surface-border rounded-xl p-4 sm:p-5 space-y-4">

      <div class="grid sm:grid-cols-2 gap-4">

        <!-- Metronome -->
        <div class="space-y-3">
          <p class="text-ivory/40 text-xs uppercase tracking-widest font-mono">Metronome</p>
          <div class="flex items-center gap-3">
            <button id="m-minus" class="w-8 h-8 rounded border border-surface-border text-ivory/50 hover:text-gold text-lg flex items-center justify-center">−</button>
            <span id="m-bpm" class="font-display text-3xl font-semibold text-ivory min-w-[52px] text-center tabular-nums">80</span>
            <button id="m-plus"  class="w-8 h-8 rounded border border-surface-border text-ivory/50 hover:text-gold text-lg flex items-center justify-center">+</button>
            <input id="m-slider" type="range" min="20" max="220" value="80" class="flex-1 accent-gold cursor-pointer" />
          </div>
          <!-- Beat dots -->
          <div id="m-dots" class="flex items-center gap-2 h-5"></div>
          <div class="flex items-center gap-3 flex-wrap">
            <!-- Time sig -->
            <div class="flex gap-1">
              {[2,3,4].map(n => (
                <button data-sig={n}
                  class={`sig-btn w-8 h-8 rounded border text-xs font-mono transition-all
                    ${n===4?'border-gold bg-gold/10 text-gold':'border-surface-border text-ivory/40 hover:border-gold/40'}`}>
                  {n}
                </button>
              ))}
            </div>
            <!-- Beat sound -->
            <select id="beat-sound"
              class="bg-surface-raised border border-surface-border text-ivory/70 text-xs rounded-lg px-2 py-1.5 focus:outline-none focus:border-gold/50">
              <option value="wood">🪵 Wood block</option>
              <option value="electronic">⚡ Electronic</option>
              <option value="drum">🥁 Drum</option>
              <option value="click">• Click</option>
            </select>
            <!-- Start/stop -->
            <button id="m-start"
              class="flex items-center gap-1.5 bg-gold hover:bg-gold-dark text-ebony text-xs font-semibold px-4 py-2 rounded-lg transition-colors ml-auto">
              <svg id="m-play-icon" class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
              <svg id="m-stop-icon" class="w-3.5 h-3.5 hidden" fill="currentColor" viewBox="0 0 24 24"><rect x="6" y="6" width="12" height="12" rx="1"/></svg>
              <span id="m-start-label">Start</span>
            </button>
          </div>
        </div>

        <!-- Recorder -->
        <div class="space-y-3 sm:border-l sm:border-surface-border sm:pl-4">
          <p class="text-ivory/40 text-xs uppercase tracking-widest font-mono">Recorder</p>
          <p class="text-ivory/40 text-xs">Records your playing. Download as WAV when done.</p>

          <div class="flex items-center gap-2">
            <!-- Record -->
            <button id="rec-btn"
              class="flex items-center gap-1.5 border border-surface-border hover:border-red-500/60 text-ivory/60 hover:text-red-400 text-xs font-medium px-4 py-2 rounded-lg transition-all">
              <span class="w-2.5 h-2.5 rounded-full bg-red-500 flex-shrink-0"></span>
              <span id="rec-label">Record</span>
            </button>
            <!-- Timer -->
            <span id="rec-timer" class="font-mono text-sm text-ivory/30">0:00</span>
            <!-- Download -->
            <a id="rec-download" href="#" download="bigpiano-recording.wav"
              class="hidden ml-auto flex items-center gap-1.5 bg-gold hover:bg-gold-dark text-ebony text-xs font-semibold px-3 py-2 rounded-lg transition-colors">
              ↓ Download
            </a>
          </div>

          <!-- Waveform visualizer -->
          <canvas id="rec-canvas" width="300" height="40"
            class="w-full rounded-lg border border-surface-border bg-surface-raised"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- SCRIPT -->
  <script>
  (function() {
    const NOTE_NAMES = ["C","C#","D","D#","E","F","F#","G","G#","A","A#","B"];
    const A4 = 440;
    function noteFreq(name, octave) {
      const idx = NOTE_NAMES.indexOf(name);
      return A4 * Math.pow(2, (idx - 9 + (octave - 4) * 12) / 12);
    }

    // ── State ──────────────────────────────────────────────────────────────
    let instrument = "piano";
    let soundType  = "grand";
    let octaveBase = 4;
    let instVol    = 0.75;
    let audioCtx   = null;
    let activeNotes = {};

    // Metronome
    let mBpm = 80, mBeats = 4, mPlaying = false;
    let mCurrentBeat = 0, mNextTime = 0, mTimerID = null;

    // Recorder
    let mediaRec = null, recChunks = [], recInterval = null, recSeconds = 0;
    let recDest  = null; // MediaStreamDestination for recording instrument audio

    // ── DOM ────────────────────────────────────────────────────────────────
    const $ = id => document.getElementById(id);
    const pianoSection   = $("piano-section");
    const kalimbaSection = $("kalimba-section");
    const pianoKeys      = $("piano-keys");
    const kalimbaTines   = $("kalimba-tines");
    const kalimbaLabels  = $("kalimba-labels");
    const soundSelect    = $("sound-select");
    const octaveCtrl     = $("octave-ctrl");
    const octDisplay     = $("oct-display");
    const instVolSlider  = $("inst-vol");
    const mBpmDisplay    = $("m-bpm");
    const mSlider        = $("m-slider");
    const mMinus         = $("m-minus");
    const mPlus          = $("m-plus");
    const mDots          = $("m-dots");
    const sigBtns        = document.querySelectorAll(".sig-btn");
    const beatSound      = $("beat-sound");
    const mStart         = $("m-start");
    const mStartLabel    = $("m-start-label");
    const mPlayIcon      = $("m-play-icon");
    const mStopIcon      = $("m-stop-icon");
    const recBtn         = $("rec-btn");
    const recLabel       = $("rec-label");
    const recTimer       = $("rec-timer");
    const recDownload    = $("rec-download");
    const recCanvas      = $("rec-canvas");
    const instBtns       = document.querySelectorAll(".inst-btn");

    // ── Audio context ──────────────────────────────────────────────────────
    function getCtx() {
      if (!audioCtx) {
        audioCtx = new AudioContext();
        // Create destination for recording
        recDest = audioCtx.createMediaStreamDestination();
      }
      if (audioCtx.state === "suspended") audioCtx.resume();
      return audioCtx;
    }

    // ── Instrument synthesizer ─────────────────────────────────────────────
    function getSoundParams() {
      switch(soundType) {
        case "grand":    return { type:"triangle", attack:0.008, decay:0.3, sustain:0.6, release:1.2, harmonics:[[2,0.3],[3,0.15],[4,0.08]] };
        case "electric": return { type:"sine",     attack:0.005, decay:0.2, sustain:0.7, release:0.8, harmonics:[[2,0.5],[3,0.2]] };
        case "soft":     return { type:"sine",     attack:0.02,  decay:0.5, sustain:0.4, release:2.0, harmonics:[[2,0.1]] };
        case "organ":    return { type:"sine",     attack:0.01,  decay:0,   sustain:1.0, release:0.1, harmonics:[[2,0.6],[3,0.4],[4,0.2],[6,0.1]] };
        default:         return { type:"triangle", attack:0.008, decay:0.3, sustain:0.6, release:1.2, harmonics:[] };
      }
    }

    function playNote(freq, duration = null) {
      const ctx    = getCtx();
      const p      = getSoundParams();
      const master = ctx.createGain();
      master.connect(ctx.destination);
      master.connect(recDest); // also route to recorder
      master.gain.setValueAtTime(0, ctx.currentTime);

      // Create oscillators (fundamental + harmonics)
      const oscs = [];
      [[1, 1.0], ...p.harmonics.map(([h, a]) => [h, a])].forEach(([harmonic, amp]) => {
        const osc  = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.type           = p.type;
        osc.frequency.value = freq * harmonic;
        gain.gain.value     = amp * instVol * 0.3;
        osc.connect(gain);
        gain.connect(master);
        osc.start(ctx.currentTime);
        oscs.push({ osc, gain });
      });

      // Envelope
      const now = ctx.currentTime;
      master.gain.linearRampToValueAtTime(1, now + p.attack);
      master.gain.linearRampToValueAtTime(p.sustain, now + p.attack + p.decay);

      function release() {
        const t = ctx.currentTime;
        master.gain.setValueAtTime(master.gain.value, t);
        master.gain.exponentialRampToValueAtTime(0.001, t + p.release);
        oscs.forEach(({ osc }) => osc.stop(t + p.release + 0.1));
      }

      if (duration) {
        // Kalimba — auto release
        setTimeout(release, duration);
      } else {
        return release; // caller releases manually
      }
    }

    // Kalimba specific (bright metallic sound)
    function playKalimbaNote(freq) {
      const ctx   = getCtx();
      const dur   = Math.max(0.8, 2.5 - freq / 1000); // longer sustain for lower notes
      const osc   = ctx.createOscillator();
      const gain  = ctx.createGain();
      const t     = ctx.currentTime;
      osc.type    = "triangle";
      osc.frequency.value = freq;
      // Add slight inharmonicity characteristic of kalimba
      osc.detune.value = 4;
      osc.connect(gain);
      gain.connect(ctx.destination);
      gain.connect(recDest);
      gain.gain.setValueAtTime(instVol * 0.6, t);
      gain.gain.exponentialRampToValueAtTime(0.001, t + dur);
      osc.start(t);
      osc.stop(t + dur + 0.05);
      // "Ping" attack character
      const osc2  = ctx.createOscillator();
      const gain2 = ctx.createGain();
      osc2.frequency.value = freq * 4;
      osc2.type = "sine";
      osc2.connect(gain2); gain2.connect(ctx.destination);
      gain2.gain.setValueAtTime(instVol * 0.15, t);
      gain2.gain.exponentialRampToValueAtTime(0.001, t + 0.08);
      osc2.start(t); osc2.stop(t + 0.1);
    }

    // ── Piano keyboard ─────────────────────────────────────────────────────
    // 2 octaves starting from octaveBase
    const WHITE_PATTERN = [0,2,4,5,7,9,11]; // C D E F G A B semitone offsets
    const BLACK_PATTERN = [1,3,-1,6,8,10,-1]; // C# D# (none) F# G# A# (none)

    function buildPianoKeys() {
      pianoKeys.innerHTML = "";
      const numOctaves = 2;
      const whiteKeys  = [];

      for (let o = 0; o < numOctaves; o++) {
        WHITE_PATTERN.forEach(semi => {
          const noteIdx = (semi) % 12;
          const freq    = noteFreq(NOTE_NAMES[semi], octaveBase + o);
          whiteKeys.push({ freq, name: NOTE_NAMES[semi], octave: octaveBase + o });
        });
      }

      const totalWhite = whiteKeys.length;
      const keyW       = `${100 / totalWhite}%`;

      whiteKeys.forEach((key, i) => {
        const el = document.createElement("div");
        el.className = [
          "white-key absolute bottom-0 rounded-b-lg border border-gray-700",
          "cursor-pointer transition-colors duration-75",
          "bg-ivory hover:bg-gold/20 active:bg-gold/40",
          "flex items-end justify-center pb-1",
        ].join(" ");
        el.style.cssText = `width:${keyW}; left:${(i/totalWhite)*100}%; height:100%`;
        el.innerHTML = `<span style="font-size:9px" class="text-ebony/30 font-mono select-none">${key.name}${key.octave}</span>`;
        el.dataset.freq = key.freq;
        pianoKeys.appendChild(el);
      });

      // Black keys
      for (let o = 0; o < numOctaves; o++) {
        BLACK_PATTERN.forEach((semi, wi) => {
          if (semi === -1) return;
          const freq = noteFreq(NOTE_NAMES[semi], octaveBase + o);
          const el   = document.createElement("div");
          el.className = [
            "black-key absolute rounded-b-lg",
            "cursor-pointer z-10 transition-colors duration-75",
            "bg-ebony hover:bg-gray-700 active:bg-gold/60",
          ].join(" ");
          // Position: between white keys wi and wi+1 in octave o
          const whitePos = o * 7 + wi + 0.65;
          el.style.cssText = `width:${60/totalWhite}%; left:${(whitePos/totalWhite)*100}%; height:62%; top:0`;
          el.dataset.freq   = freq;
          el.style.boxShadow = "0 4px 8px rgba(0,0,0,0.6)";
          pianoKeys.appendChild(el);
        });
      }

      // Events
      pianoKeys.querySelectorAll("[data-freq]").forEach(key => {
        const freq = parseFloat(key.dataset.freq);
        let releaser = null;

        key.addEventListener("mousedown",  e => { e.preventDefault(); releaser = playNote(freq); key.classList.add("active"); });
        key.addEventListener("mouseup",    () => { if(releaser){releaser();releaser=null;} key.classList.remove("active"); });
        key.addEventListener("mouseleave", () => { if(releaser){releaser();releaser=null;} key.classList.remove("active"); });
        key.addEventListener("touchstart", e => { e.preventDefault(); releaser = playNote(freq); });
        key.addEventListener("touchend",   () => { if(releaser){releaser();releaser=null;} });
      });
    }

    // ── Kalimba tines ──────────────────────────────────────────────────────
    // Standard 17-key kalimba notes (C4 centered)
    const KALIMBA_NOTES = [
      {name:"D5",o:5},{name:"B4",o:4},{name:"G4",o:4},{name:"E4",o:4},{name:"C4",o:4},
      {name:"A3",o:3},{name:"F3",o:3},{name:"D3",o:3},{name:"C3",o:3},
      {name:"E3",o:3},{name:"G3",o:3},{name:"B3",o:3},{name:"D4",o:4},
      {name:"F4",o:4},{name:"A4",o:4},{name:"C5",o:5},{name:"E5",o:5},
    ];

    function buildKalimba() {
      kalimbaTines.innerHTML = "";
      kalimbaLabels.innerHTML = "";
      const center = Math.floor(KALIMBA_NOTES.length / 2);
      KALIMBA_NOTES.forEach((note, i) => {
        const freq    = noteFreq(note.name.replace(/\d/,""), note.o);
        const dist    = Math.abs(i - center);
        const height  = 40 + dist * 8; // longer tines toward center (lower notes)
        const tine    = document.createElement("button");
        tine.className = "tine flex-shrink-0 rounded-t-full cursor-pointer transition-all active:scale-95 border-2 border-gold/30 hover:border-gold";
        tine.style.cssText = `width:22px; height:${height}px; background: linear-gradient(180deg, #E8CC80 0%, #8C6A1F 100%);`;
        tine.dataset.freq   = freq;
        tine.addEventListener("mousedown",  e => { e.preventDefault(); playKalimbaNote(freq); tine.style.opacity="0.6"; });
        tine.addEventListener("mouseup",    () => { tine.style.opacity="1"; });
        tine.addEventListener("touchstart", e => { e.preventDefault(); playKalimbaNote(freq); });
        kalimbaTines.appendChild(tine);

        const label = document.createElement("span");
        label.className = "text-ivory/40 font-mono flex-shrink-0 text-center";
        label.style.cssText = "width:22px; font-size:9px";
        label.textContent = note.name;
        kalimbaLabels.appendChild(label);
      });
    }

    // ── Keyboard shortcuts ─────────────────────────────────────────────────
    const KEY_MAP = {
      "a":"C","w":"C#","s":"D","e":"D#","d":"E","f":"F",
      "t":"F#","g":"G","y":"G#","h":"A","u":"A#","j":"B",
      "k":"C","o":"C#","l":"D",
    };
    const heldKeys = new Set();
    const keyReleasers = {};

    document.addEventListener("keydown", e => {
      if (e.target instanceof HTMLInputElement || e.target instanceof HTMLSelectElement) return;
      if (e.repeat) return;
      const k = e.key.toLowerCase();
      if (instrument === "piano" && KEY_MAP[k]) {
        const noteName = KEY_MAP[k];
        const isOctaveUp = ["k","o","l"].includes(k);
        const freq = noteFreq(noteName, octaveBase + (isOctaveUp ? 1 : 0));
        const rel  = playNote(freq);
        keyReleasers[k] = rel;
        // Highlight key
        pianoKeys.querySelectorAll("[data-freq]").forEach(el => {
          if (Math.abs(parseFloat(el.dataset.freq) - freq) < 0.5) el.classList.add("active");
        });
      }
    });

    document.addEventListener("keyup", e => {
      const k = e.key.toLowerCase();
      if (keyReleasers[k]) { keyReleasers[k](); delete keyReleasers[k]; }
      pianoKeys.querySelectorAll(".active").forEach(el => el.classList.remove("active"));
    });

    // ── Metronome ──────────────────────────────────────────────────────────
    function buildMDots() {
      mDots.innerHTML = "";
      for (let i = 0; i < mBeats; i++) {
        const d = document.createElement("div");
        d.className = "w-3 h-3 rounded-full border border-" + (i===0?"gold":"surface-border");
        d.dataset.i = i;
        mDots.appendChild(d);
      }
    }

    function flashMDot(idx) {
      const dots = mDots.querySelectorAll("div");
      const d = dots[idx];
      if (!d) return;
      d.classList.add(idx===0?"bg-gold":"bg-ivory/60");
      setTimeout(() => d.classList.remove("bg-gold","bg-ivory/60"), 80);
    }

    function mClick(time, isAccent) {
      const ctx  = getCtx();
      const type = beatSound.value;
      const osc  = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.connect(gain);
      gain.connect(ctx.destination);
      gain.connect(recDest);

      switch(type) {
        case "wood":
          osc.type = "triangle";
          osc.frequency.value = isAccent ? 900 : 700;
          gain.gain.setValueAtTime(0.5, time);
          gain.gain.exponentialRampToValueAtTime(0.001, time + 0.07);
          break;
        case "electronic":
          osc.type = "sine";
          osc.frequency.value = isAccent ? 1200 : 800;
          osc.frequency.exponentialRampToValueAtTime(isAccent?800:400, time+0.05);
          gain.gain.setValueAtTime(0.6, time);
          gain.gain.exponentialRampToValueAtTime(0.001, time + 0.08);
          break;
        case "drum":
          osc.type = "sine";
          osc.frequency.setValueAtTime(isAccent?200:150, time);
          osc.frequency.exponentialRampToValueAtTime(30, time + 0.12);
          gain.gain.setValueAtTime(0.8, time);
          gain.gain.exponentialRampToValueAtTime(0.001, time + 0.15);
          break;
        case "click":
        default:
          osc.type = "square";
          osc.frequency.value = isAccent ? 1050 : 820;
          gain.gain.setValueAtTime(0.4, time);
          gain.gain.exponentialRampToValueAtTime(0.001, time + 0.05);
      }
      osc.start(time);
      osc.stop(time + 0.2);
    }

    function mScheduler() {
      const ctx = getCtx();
      while (mNextTime < ctx.currentTime + 0.12) {
        mClick(mNextTime, mCurrentBeat === 0);
        const bi = mCurrentBeat;
        const delay = Math.max(0, (mNextTime - ctx.currentTime) * 1000);
        setTimeout(() => flashMDot(bi), delay);
        mNextTime += 60 / mBpm;
        mCurrentBeat = (mCurrentBeat + 1) % mBeats;
      }
    }

    function startMetronome() {
      const ctx = getCtx(); mCurrentBeat = 0; mNextTime = ctx.currentTime + 0.05;
      mTimerID = setInterval(mScheduler, 25);
      mPlaying = true;
      mStartLabel.textContent = "Stop";
      mPlayIcon.classList.add("hidden"); mStopIcon.classList.remove("hidden");
      mStart.classList.replace("bg-gold","bg-red-700");
      mStart.classList.replace("hover:bg-gold-dark","hover:bg-red-900");
      mStart.classList.replace("text-ebony","text-white");
    }

    function stopMetronome() {
      clearInterval(mTimerID); mPlaying = false;
      mStartLabel.textContent = "Start";
      mPlayIcon.classList.remove("hidden"); mStopIcon.classList.add("hidden");
      mStart.classList.replace("bg-red-700","bg-gold");
      mStart.classList.replace("hover:bg-red-900","hover:bg-gold-dark");
      mStart.classList.replace("text-white","text-ebony");
    }

    function setMBpm(val) {
      mBpm = Math.min(220, Math.max(20, Math.round(val)));
      mBpmDisplay.textContent = mBpm;
      mSlider.value = mBpm;
    }

    mMinus.addEventListener("click", () => setMBpm(mBpm-1));
    mPlus.addEventListener("click",  () => setMBpm(mBpm+1));
    mSlider.addEventListener("input",() => setMBpm(mSlider.value));
    mStart.addEventListener("click", () => { if(mPlaying) stopMetronome(); else startMetronome(); });

    sigBtns.forEach(b => b.addEventListener("click", () => {
      mBeats = Number(b.dataset.sig); mCurrentBeat = 0; buildMDots();
      sigBtns.forEach(s => {
        const a = Number(s.dataset.sig) === mBeats;
        s.classList.toggle("border-gold",a); s.classList.toggle("bg-gold/10",a); s.classList.toggle("text-gold",a);
        s.classList.toggle("border-surface-border",!a); s.classList.toggle("text-ivory/40",!a);
      });
    }));

    // ── Recorder ──────────────────────────────────────────────────────────
    let isRecording = false;
    const canvasCtx = recCanvas.getContext("2d");

    function formatTime(s) {
      return `${Math.floor(s/60)}:${String(s%60).padStart(2,"0")}`;
    }

    async function startRecording() {
      getCtx(); // init audio context + recDest
      mediaRec  = new MediaRecorder(recDest.stream);
      recChunks = [];
      mediaRec.ondataavailable = e => { if(e.data.size>0) recChunks.push(e.data); };
      mediaRec.onstop = () => {
        const blob = new Blob(recChunks, { type:"audio/wav" });
        const url  = URL.createObjectURL(blob);
        recDownload.href = url;
        recDownload.classList.remove("hidden");
      };
      mediaRec.start(100);
      isRecording = true; recSeconds = 0;
      recLabel.textContent = "Stop";
      recBtn.classList.add("border-red-500/60","text-red-400");
      recDownload.classList.add("hidden");
      recInterval = setInterval(() => {
        recSeconds++;
        recTimer.textContent = formatTime(recSeconds);
        drawWave();
      }, 1000);
    }

    function stopRecording() {
      mediaRec.stop();
      isRecording = false;
      recLabel.textContent = "Record";
      recBtn.classList.remove("border-red-500/60","text-red-400");
      clearInterval(recInterval);
    }

    function drawWave() {
      const W = recCanvas.width, H = recCanvas.height;
      canvasCtx.fillStyle = "#1C1C1C";
      canvasCtx.fillRect(0,0,W,H);
      if (!audioCtx) return;
      // Simple animated wave while recording
      canvasCtx.strokeStyle = "#C9A84C";
      canvasCtx.lineWidth   = 1.5;
      canvasCtx.beginPath();
      for (let x=0; x<W; x++) {
        const y = H/2 + Math.sin((x*0.08)+recSeconds*2)*8 + Math.sin((x*0.13)+recSeconds)*4;
        x===0 ? canvasCtx.moveTo(x,y) : canvasCtx.lineTo(x,y);
      }
      canvasCtx.stroke();
    }

    recBtn.addEventListener("click", () => {
      if (isRecording) stopRecording(); else startRecording();
    });

    // ── Instrument switcher ────────────────────────────────────────────────
    instBtns.forEach(btn => {
      btn.addEventListener("click", () => {
        instrument = btn.dataset.inst;
        instBtns.forEach(b => {
          const a = b === btn;
          b.classList.toggle("bg-gold",a); b.classList.toggle("text-ebony",a);
          b.classList.toggle("text-ivory/50",!a);
        });
        if (instrument === "piano") {
          pianoSection.classList.remove("hidden");
          kalimbaSection.classList.add("hidden");
          soundSelect.classList.remove("hidden");
          octaveCtrl.classList.remove("hidden");
        } else {
          pianoSection.classList.add("hidden");
          kalimbaSection.classList.remove("hidden");
          soundSelect.classList.add("hidden");
          octaveCtrl.classList.add("hidden");
          buildKalimba();
        }
      });
    });

    soundSelect.addEventListener("change", () => { soundType = soundSelect.value; });
    instVolSlider.addEventListener("input", () => { instVol = instVolSlider.value / 100; });
    $("oct-down").addEventListener("click", () => { if(octaveBase>2){octaveBase--; octDisplay.textContent=octaveBase; buildPianoKeys();} });
    $("oct-up").addEventListener("click",   () => { if(octaveBase<6){octaveBase++; octDisplay.textContent=octaveBase; buildPianoKeys();} });

    // ── Init ───────────────────────────────────────────────────────────────
    buildPianoKeys();
    buildMDots();
    drawWave();

  })();
  </script>

  <style>
    .white-key.active { background: rgba(201,168,76,0.4) !important; }
    .black-key.active { background: rgba(201,168,76,0.7) !important; }
  </style>

</Layout>
