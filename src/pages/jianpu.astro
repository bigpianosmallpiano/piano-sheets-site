---
// src/pages/jianpu.astro
// 简谱 → Staff Notation Converter
import Layout from "../layouts/Layout.astro";
import CoffeeButton from "../components/CoffeeButton.astro";
---

<Layout
  title="Jianpu 简谱 to Staff Notation Converter | Big Piano Small Piano"
  description="Convert jianpu (numbered notation 简谱) to standard treble/bass clef staff notation. Free online tool for piano learners. Supports key signatures, time signatures, lyrics and chord analysis."
>

  <!-- HERO -->
  <section class="relative overflow-hidden border-b border-surface-border">
    <div class="absolute inset-0 bg-keys-pattern opacity-50 pointer-events-none"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold to-transparent"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 py-8 sm:py-12 text-center flex flex-col items-center gap-2">
      <p class="text-gold text-xs tracking-[0.25em] uppercase font-mono">Learning tool</p>
      <h1 class="font-display text-4xl sm:text-5xl font-semibold text-ivory leading-tight">
        简谱 <span class="italic text-gold">to Staff</span>
      </h1>
      <p class="text-ivory/50 text-sm max-w-lg leading-relaxed">
        Convert jianpu (numbered notation) to treble or bass clef staff notation.
        Supports key signatures, time signatures, lyrics and chord analysis.
      </p>
    </div>
  </section>

  <!-- CONTROLS -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-6 space-y-4">

    <!-- Input row -->
    <div class="bg-surface border border-surface-border rounded-xl p-4 space-y-3">
      <div class="flex flex-wrap items-center gap-3 mb-1">
        <p class="text-gold text-xs tracking-[0.2em] uppercase font-mono">Jianpu input</p>
        <span class="text-ivory/30 text-xs">Use numbers 1–7, 0=rest, - =hold, | =barline, ' =high octave, , =low octave, _ =eighth note</span>
      </div>
      <textarea id="jianpu-input"
        class="w-full bg-surface-raised border border-surface-border rounded-lg px-3 py-2.5 text-ivory text-sm font-mono leading-relaxed resize-none focus:outline-none focus:border-gold/50 placeholder-ivory/20"
        rows="4"
        placeholder="e.g.   1 2 3 4 | 5 5 - - | 6 6 5 - | 4 4 3 2 | 1 - - - |"></textarea>

      <!-- Lyrics -->
      <div class="flex items-center gap-2">
        <label class="text-ivory/50 text-xs flex-shrink-0">Lyrics:</label>
        <input id="lyrics-input" type="text"
          class="flex-1 bg-surface-raised border border-surface-border rounded-lg px-3 py-1.5 text-ivory text-xs font-mono focus:outline-none focus:border-gold/50 placeholder-ivory/20"
          placeholder="space-separated syllables: do re mi fa sol" />
      </div>
    </div>

    <!-- Options row -->
    <div class="bg-surface border border-surface-border rounded-xl p-4">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">

        <!-- Key -->
        <div class="space-y-1.5">
          <label class="text-ivory/50 text-xs uppercase tracking-wide font-mono">Key</label>
          <select id="key-select"
            class="w-full bg-surface-raised border border-surface-border text-ivory/80 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-gold/50">
            <option value="C">C major</option>
            <option value="G">G major</option>
            <option value="D">D major</option>
            <option value="A">A major</option>
            <option value="F">F major</option>
            <option value="Bb">B♭ major</option>
            <option value="Eb">E♭ major</option>
          </select>
        </div>

        <!-- Time signature -->
        <div class="space-y-1.5">
          <label class="text-ivory/50 text-xs uppercase tracking-wide font-mono">Time</label>
          <select id="time-select"
            class="w-full bg-surface-raised border border-surface-border text-ivory/80 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-gold/50">
            <option value="4/4">4/4</option>
            <option value="3/4">3/4</option>
            <option value="2/4">2/4</option>
          </select>
        </div>

        <!-- Clef -->
        <div class="space-y-1.5">
          <label class="text-ivory/50 text-xs uppercase tracking-wide font-mono">Clef</label>
          <select id="clef-select"
            class="w-full bg-surface-raised border border-surface-border text-ivory/80 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-gold/50">
            <option value="treble">Treble 𝄞</option>
            <option value="bass">Bass 𝄢</option>
            <option value="grand">Grand Staff</option>
          </select>
        </div>

        <!-- Bars per row -->
        <div class="space-y-1.5">
          <label class="text-ivory/50 text-xs uppercase tracking-wide font-mono">Bars/row</label>
          <select id="bars-per-row"
            class="w-full bg-surface-raised border border-surface-border text-ivory/80 text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-gold/50">
            <option value="4" selected>4</option>
            <option value="3">3</option>
            <option value="5">5</option>
            <option value="6">6</option>
          </select>
        </div>
      </div>

      <!-- Checkboxes row -->
      <div class="flex flex-wrap gap-4 mt-3 pt-3 border-t border-surface-border">
        <label class="flex items-center gap-2 cursor-pointer select-none">
          <input type="checkbox" id="show-chords" class="w-4 h-4 accent-gold" />
          <span class="text-ivory/60 text-sm">Chord analysis</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer select-none">
          <input type="checkbox" id="show-note-names" class="w-4 h-4 accent-gold" checked />
          <span class="text-ivory/60 text-sm">Note names</span>
        </label>
      </div>
    </div>

    <!-- Action buttons -->
    <div class="flex flex-wrap gap-3">
      <button id="convert-btn"
        class="flex-1 sm:flex-none inline-flex items-center justify-center gap-2 bg-gold hover:bg-gold-dark text-ebony font-semibold text-sm px-6 py-3 rounded-xl transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2z"/>
        </svg>
        Convert to Staff
      </button>
      <button id="export-png"
        class="inline-flex items-center gap-2 border border-surface-border hover:border-gold/50 text-ivory/70 hover:text-gold text-sm px-4 py-3 rounded-xl transition-all hidden">
        ↓ PNG
      </button>
      <button id="export-pdf"
        class="inline-flex items-center gap-2 border border-surface-border hover:border-gold/50 text-ivory/70 hover:text-gold text-sm px-4 py-3 rounded-xl transition-all hidden">
        ↓ PDF
      </button>
      <button id="clear-btn"
        class="inline-flex items-center gap-2 border border-surface-border hover:border-gold/40 text-ivory/40 hover:text-gold text-sm px-4 py-3 rounded-xl transition-all">
        Clear
      </button>
    </div>
  </div>

  <!-- OUTPUT STAFF -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-4 pb-4">
    <div id="output-container" class="bg-surface border border-surface-border rounded-xl overflow-hidden hidden">
      <div class="px-4 pt-3 pb-1 flex items-center justify-between">
        <p class="text-gold text-xs tracking-[0.2em] uppercase font-mono">Staff notation</p>
        <p id="output-info" class="text-ivory/30 text-xs font-mono"></p>
      </div>
      <div id="staff-scroll" class="overflow-x-auto p-4">
        <svg id="staff-svg" xmlns="http://www.w3.org/2000/svg"></svg>
      </div>
    </div>

    <!-- Empty state -->
    <div id="empty-state" class="bg-surface border border-surface-border rounded-xl p-12 text-center">
      <p class="font-display text-2xl text-ivory/20 italic mb-2">Enter jianpu above and click Convert</p>
      <p class="text-ivory/25 text-xs">e.g. &nbsp;<code class="font-mono bg-surface-raised px-2 py-1 rounded">1 2 3 4 | 5 - - - | 6 5 4 3 | 2 - - - |</code></p>
    </div>
  </div>

  <!-- JIANPU REFERENCE -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pb-8">
    <div class="bg-surface border border-surface-border rounded-xl p-5">
      <p class="text-gold text-xs tracking-[0.2em] uppercase font-mono mb-4">Jianpu notation guide</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 text-xs">
        {[
          { sym:"1 2 3 4 5 6 7", desc:"Scale degrees (do re mi fa sol la si)" },
          { sym:"0",             desc:"Rest" },
          { sym:"-",             desc:"Hold / extend previous note" },
          { sym:"|",             desc:"Bar line" },
          { sym:"1'  2'",        desc:"High octave (add ' after)" },
          { sym:"1,  2,",        desc:"Low octave (add , after)" },
          { sym:"1_",            desc:"Eighth note (add _ after)" },
          { sym:"1__",           desc:"Sixteenth note (add __ after)" },
          { sym:"Lyrics below",  desc:"Space-separated syllables in the lyrics box" },
        ].map(item => (
          <div class="flex gap-3 items-start">
            <code class="font-mono text-gold bg-surface-raised px-2 py-1 rounded flex-shrink-0 text-xs">{item.sym}</code>
            <span class="text-ivory/50 leading-relaxed">{item.desc}</span>
          </div>
        ))}
      </div>
    </div>
    <div class="mt-4">
      <CoffeeButton variant="inline" message="Enjoying the free tools? A coffee helps keep them free for everyone." />
    </div>
  </div>

  <!-- ════════════════════════ SCRIPT ════════════════════════════════════════ -->
  <script>
  (function () {

    // ── DOM ──────────────────────────────────────────────────────────────────
    const inputEl      = document.getElementById("jianpu-input");
    const lyricsEl     = document.getElementById("lyrics-input");
    const keyEl        = document.getElementById("key-select");
    const timeEl       = document.getElementById("time-select");
    const clefEl       = document.getElementById("clef-select");
    const barsRowEl    = document.getElementById("bars-per-row");
    const showChordsEl = document.getElementById("show-chords");
    const showNamesEl  = document.getElementById("show-note-names");
    const convertBtn   = document.getElementById("convert-btn");
    const exportPng    = document.getElementById("export-png");
    const exportPdf    = document.getElementById("export-pdf");
    const clearBtn     = document.getElementById("clear-btn");
    const outputCont   = document.getElementById("output-container");
    const emptyState   = document.getElementById("empty-state");
    const staffSvg     = document.getElementById("staff-svg");
    const outputInfo   = document.getElementById("output-info");

    // ── Key definitions ──────────────────────────────────────────────────────
    // For each key: the pitch of scale degree 1 (C4=0, D4=2, etc. in semitones from C4)
    // and the accidentals to show on the staff
    const KEYS = {
      "C":  { root: 0,  accidentals: [],                                type: "sharp" },
      "G":  { root: 7,  accidentals: ["F"],                             type: "sharp" },
      "D":  { root: 2,  accidentals: ["F","C"],                         type: "sharp" },
      "A":  { root: 9,  accidentals: ["F","C","G"],                     type: "sharp" },
      "F":  { root: 5,  accidentals: ["B"],                             type: "flat"  },
      "Bb": { root: 10, accidentals: ["B","E"],                         type: "flat"  },
      "Eb": { root: 3,  accidentals: ["B","E","A"],                     type: "flat"  },
    };

    // Diatonic intervals for major scale (semitones from root)
    const MAJOR_SCALE = [0, 2, 4, 5, 7, 9, 11];

    // Note names
    const NOTE_NAMES  = ["C","C#","D","D#","E","F","F#","G","G#","A","A#","B"];
    const DIATONIC    = ["C","D","E","F","G","A","B"];

    // ── Parser ───────────────────────────────────────────────────────────────
    function parseJianpu(text, key, timeSig) {
      const keyInfo  = KEYS[key] || KEYS["C"];
      const rootMidi = 60 + keyInfo.root; // MIDI of scale degree 1 starting at C4 octave

      const beatsPerBar = parseInt(timeSig.split("/")[0]);
      const tokens = text.trim().split(/\s+/);
      const bars   = [];
      let   curBar = [];

      for (const tok of tokens) {
        if (tok === "|") {
          if (curBar.length) bars.push(curBar);
          curBar = [];
          continue;
        }

        // Parse duration modifiers
        let dur = "quarter";
        let t   = tok;
        if (t.endsWith("__")) { dur = "sixteenth"; t = t.slice(0,-2); }
        else if (t.endsWith("_")) { dur = "eighth"; t = t.slice(0,-1); }

        // Hold sign
        if (t === "-") {
          curBar.push({ type:"hold", dur });
          continue;
        }
        // Rest
        if (t === "0") {
          curBar.push({ type:"rest", dur });
          continue;
        }

        // Dotted duration (e.g. 1.)
        let dotted = false;
        if (t.endsWith(".")) { dotted = true; t = t.slice(0,-1); }

        // Octave markers
        let octShift = 0;
        while (t.endsWith("'")) { octShift++; t = t.slice(0,-1); }
        while (t.endsWith(",")) { octShift--; t = t.slice(0,-1); }

        const degree = parseInt(t);
        if (isNaN(degree) || degree < 1 || degree > 7) continue;

        // Convert scale degree to MIDI pitch
        // Scale degree 1 = rootMidi (e.g. C4 in C major)
        // We need to ensure ascending scale stays in reasonable octave
        const semitones = MAJOR_SCALE[degree - 1];
        let midi = rootMidi + semitones + octShift * 12;

        // Keep notes in a sensible range (treble: MIDI 60-84, bass: 36-60)
        // Adjust by octave so they fit
        while (midi > 84) midi -= 12;
        while (midi < 48) midi += 12;

        curBar.push({ type:"note", degree, midi, dur, dotted });
      }
      if (curBar.length) bars.push(curBar);
      return bars;
    }

    // MIDI → note name + octave
    function midiToNote(midi) {
      const oct  = Math.floor(midi / 12) - 1;
      const name = NOTE_NAMES[midi % 12];
      return { name, oct };
    }

    // Diatonic position (steps from C4)
    function diatonicPos(name, oct) {
      const base = name.replace("#","").replace("b","");
      const b    = DIATONIC.indexOf(base);
      return b === -1 ? null : (oct - 4) * 7 + b;
    }

    // ── SVG staff renderer ───────────────────────────────────────────────────
    const SVG_NS  = "http://www.w3.org/2000/svg";
    const SP      = 8;     // pixels per staff space
    const STAFF_H = 4*SP;  // 32px
    const ROW_H   = 90;    // px per staff row (staff + space for lyrics/chords above)
    const PAPER_W = 800;   // fixed paper width

    // Staff geometry within a row
    const STAFF_TOP = 28;  // Y of top staff line within a row (leaves space for chord names)
    // refY within a row = bottom staff line Y
    const REF_Y_IN_ROW = STAFF_TOP + STAFF_H;

    const COLORS = {
      bg:     "#141414",
      staff:  "rgba(248,245,238,0.28)",
      clef:   "#C9A84C",
      note:   "#F8F5EE",
      gold:   "#C9A84C",
      rest:   "rgba(248,245,238,0.6)",
      text:   "rgba(248,245,238,0.7)",
      chord:  "#C9A84C",
      acc:    "#7CB9E8",
      bar:    "rgba(248,245,238,0.35)",
      lyrics: "rgba(248,245,238,0.6)",
    };

    // Key signature accidental positions on treble staff (diatonic pos)
    const TREBLE_ACC_POS = { "F":10, "C":7, "G":11, "D":8, "A":5, "E":9, "B":6 };
    const BASS_ACC_POS   = { "F":3,  "C":0, "G":4,  "D":1, "A":-2,"E":2, "B":-1 };
    // Flat positions differ slightly
    const TREBLE_FLAT_POS = { "B":6, "E":9, "A":5, "D":8, "G":4, "C":7, "F":10 };
    const BASS_FLAT_POS   = { "B":-1,"E":2, "A":-2,"D":1, "G":-3,"C":0, "F":3  };

    function el(tag, attrs={}, children=[]) {
      const e = document.createElementNS(SVG_NS, tag);
      for (const [k,v] of Object.entries(attrs)) e.setAttribute(k, v);
      for (const c of children) if (c) e.appendChild(c);
      return e;
    }

    function txt(content, x, y, opts={}) {
      return el("text", {
        x, y,
        fill:        opts.fill || COLORS.text,
        "font-size": opts.size || 10,
        "font-family": opts.font || "'DM Sans', sans-serif",
        "text-anchor": opts.anchor || "middle",
        "font-weight": opts.weight || "normal",
        ...opts.extra,
      }, [document.createTextNode(content)]);
    }

    // Y within a row for a diatonic position (relative to row top=0)
    function noteY(dp, clefName) {
      // Bottom staff line dp
      const botDp = clefName === "bass" ? -10 : 2;
      return REF_Y_IN_ROW - (dp - botDp) * (SP / 2);
    }

    // Draw 5 staff lines for one row
    function drawStaffLines(rowG, clefName, startX, endX) {
      for (let i = 0; i <= 4; i++) {
        const y = STAFF_TOP + i * SP;
        rowG.appendChild(el("line", {
          x1:y, y1:y, x2:endX, y2:y,   // fix: use x1/y1 correctly
          stroke: COLORS.staff, "stroke-width":"0.8",
        }));
        // Redo with correct attribute names
        const line = el("line", {
          x1: startX, y1: STAFF_TOP + (4-i)*SP,
          x2: endX,   y2: STAFF_TOP + (4-i)*SP,
          stroke: COLORS.staff, "stroke-width": "0.8",
        });
        rowG.appendChild(line);
      }
    }

    // Draw clef at start of row
    function drawClef(rowG, clefName, x) {
      const char = clefName === "bass" ? "\u{1D122}" : "\u{1D11E}";
      const size = clefName === "bass" ? SP * 5.5 : SP * 10;
      // Treble: baseline so curl lands on G line (line 2 from bottom = STAFF_TOP + 3*SP)
      // Bass: baseline at ~REF_Y_IN_ROW - SP * 0.2
      const baseY = clefName === "treble"
        ? STAFF_TOP + 3*SP + SP * 1.8
        : REF_Y_IN_ROW - SP * 0.2;
      rowG.appendChild(el("text", {
        x, y: baseY,
        fill: COLORS.clef,
        "font-size":   size,
        "font-family": "'Noto Music','FreeSerif',serif",
        "text-anchor": "start",
      }, [document.createTextNode(char)]));
    }

    // Draw key signature accidentals
    function drawKeySig(rowG, keyName, clefName, startX) {
      const info = KEYS[keyName];
      if (!info || !info.accidentals.length) return startX;
      const isSharp = info.type === "sharp";
      const posMap  = isSharp
        ? (clefName === "bass" ? BASS_ACC_POS  : TREBLE_ACC_POS)
        : (clefName === "bass" ? BASS_FLAT_POS : TREBLE_FLAT_POS);
      const char = isSharp ? "♯" : "♭";
      let x = startX;
      for (const note of info.accidentals) {
        const dp = posMap[note];
        if (dp === undefined) continue;
        const y = noteY(dp, clefName);
        rowG.appendChild(el("text", {
          x, y: y + 4,
          fill: COLORS.clef,
          "font-size": SP * 1.6,
          "font-family": "serif",
          "text-anchor": "middle",
        }, [document.createTextNode(char)]));
        x += SP * 1.4;
      }
      return x;
    }

    // Draw time signature
    function drawTimeSig(rowG, timeSig, x) {
      const [num, den] = timeSig.split("/");
      rowG.appendChild(txt(num, x, STAFF_TOP + SP * 1.5, { size: SP*2, weight:"bold", fill: COLORS.clef }));
      rowG.appendChild(txt(den, x, STAFF_TOP + SP * 3.2, { size: SP*2, weight:"bold", fill: COLORS.clef }));
      return x + SP * 2.5;
    }

    // Draw a notehead at dp position within row
    function drawNotehead(rowG, x, dp, clefName, isActive, isAccid, isLandmark) {
      const y  = noteY(dp, clefName);
      const rx = SP * 0.52, ry = SP * 0.37;
      const fill = isLandmark ? COLORS.gold : isAccid ? COLORS.acc : COLORS.note;
      rowG.appendChild(el("ellipse", {
        cx: x, cy: y, rx, ry,
        transform: `rotate(-8,${x},${y})`,
        fill,
      }));
      return y;
    }

    // Draw stem
    function drawStem(rowG, x, noteY, dp, clefName) {
      const midDp   = clefName === "bass" ? -6 : 6;
      const stemUp  = dp < midDp;
      const rx      = SP * 0.52;
      const stemLen = SP * 3.5;
      const stemX   = x + (stemUp ? rx * 0.9 : -rx * 0.9);
      rowG.appendChild(el("line", {
        x1: stemX, y1: noteY,
        x2: stemX, y2: noteY + (stemUp ? -stemLen : stemLen),
        stroke: COLORS.note, "stroke-width": "1.4",
      }));
      return { stemUp, stemX, stemY: noteY + (stemUp ? -stemLen : stemLen) };
    }

    // Draw flag for eighth/sixteenth
    function drawFlag(rowG, stemX, stemEndY, stemUp, count) {
      for (let i = 0; i < count; i++) {
        const startY = stemEndY + i * (stemUp ? 5 : -5);
        const cp1x = stemX + (stemUp ? 10 : -10);
        const cp2x = stemX + (stemUp ? 12 : -12);
        const endY = startY + (stemUp ? 14 : -14);
        rowG.appendChild(el("path", {
          d: `M${stemX},${startY} C${cp1x},${startY} ${cp2x},${endY} ${stemX},${endY + (stemUp ? -4 : 4)}`,
          fill: "none", stroke: COLORS.note, "stroke-width":"1.4", "stroke-linecap":"round",
        }));
      }
    }

    // Draw ledger lines
    function drawLedgerLines(rowG, x, dp, clefName) {
      const botDp = clefName === "bass" ? -10 : 2;
      const topDp = clefName === "bass" ? -2  : 10;
      const rx    = SP * 0.52;
      const lw    = rx * 1.9;
      for (let p = botDp - 2; p >= dp; p -= 2) {
        const ly = noteY(p, clefName);
        rowG.appendChild(el("line",{x1:x-lw,y1:ly,x2:x+lw,y2:ly,stroke:COLORS.rest,"stroke-width":"1.2"}));
      }
      for (let p = topDp + 2; p <= dp; p += 2) {
        const ly = noteY(p, clefName);
        rowG.appendChild(el("line",{x1:x-lw,y1:ly,x2:x+lw,y2:ly,stroke:COLORS.rest,"stroke-width":"1.2"}));
      }
    }

    // Draw rest symbol
    function drawRest(rowG, x, clefName) {
      const y = noteY(clefName === "bass" ? -6 : 6, clefName);
      rowG.appendChild(el("rect", {
        x: x-5, y: y-3, width:10, height:5,
        fill: COLORS.rest,
      }));
    }

    // ── Chord detection ──────────────────────────────────────────────────────
    const CHORD_NAMES = ["I","II","III","IV","V","VI","VII"];
    function detectChord(notes, key) {
      if (!notes.length) return null;
      const degrees = [...new Set(notes.map(n => n.degree).filter(Boolean))];
      if (!degrees.length) return null;
      // Simple: first degree = root, label with Roman numeral
      const root = degrees[0];
      return { roman: CHORD_NAMES[root-1] || "?", degree: root };
    }

    // ── Main render ──────────────────────────────────────────────────────────
    function render() {
      const raw        = inputEl.value.trim();
      if (!raw) return;

      const key        = keyEl.value;
      const timeSig    = timeEl.value;
      const clefMode   = clefEl.value;
      const barsPerRow = parseInt(barsRowEl.value);
      const doChords   = showChordsEl.checked;
      const doNames    = showNamesEl.checked;
      const lyricsRaw  = lyricsEl.value.trim();
      const lyrics     = lyricsRaw ? lyricsRaw.split(/\s+/) : [];
      let   lyricIdx   = 0;

      const bars   = parseJianpu(raw, key, timeSig);
      const clefs  = clefMode === "grand" ? ["treble","bass"] : [clefMode];
      const numRows = Math.ceil(bars.length / barsPerRow);

      // SVG dimensions
      const clefZone  = 60;
      const barW      = (PAPER_W - clefZone) / barsPerRow;
      const noteW     = barW / 6;   // space per note within a bar
      const rowH      = clefMode === "grand" ? ROW_H * 2 + 20 : ROW_H;
      const svgH      = numRows * rowH + 20;

      staffSvg.innerHTML = "";
      staffSvg.setAttribute("width",  PAPER_W);
      staffSvg.setAttribute("height", svgH);
      staffSvg.setAttribute("viewBox", `0 0 ${PAPER_W} ${svgH}`);
      staffSvg.style.background = COLORS.bg;

      // Background
      staffSvg.appendChild(el("rect",{x:0,y:0,width:PAPER_W,height:svgH,fill:COLORS.bg}));

      for (let rowIdx = 0; rowIdx < numRows; rowIdx++) {
        const rowBars = bars.slice(rowIdx * barsPerRow, (rowIdx+1) * barsPerRow);
        const rowTopY = rowIdx * rowH + 10;

        for (const clefName of clefs) {
          const clefOffset = clefMode === "grand" && clefName === "bass" ? ROW_H + 10 : 0;
          const rY = rowTopY + clefOffset;

          const rowG = el("g", { transform: `translate(0,${rY})` });

          // Staff lines
          drawStaffLines(rowG, clefName, 0, PAPER_W);

          // Clef
          let curX = 4;
          drawClef(rowG, clefName, curX);
          curX += clefName === "bass" ? 28 : 34;

          // Key signature
          curX = drawKeySig(rowG, key, clefName, curX);
          curX += 4;

          // Time signature (first row only)
          if (rowIdx === 0) {
            curX = drawTimeSig(rowG, timeSig, curX);
          }

          curX = clefZone;

          // Bars
          rowBars.forEach((bar, bi) => {
            const barStartX = clefZone + bi * barW;
            const barEndX   = barStartX + barW;

            // Bar line at start (except very first)
            if (bi > 0 || rowIdx > 0) {
              rowG.appendChild(el("line",{
                x1:barStartX,y1:STAFF_TOP,
                x2:barStartX,y2:STAFF_TOP+STAFF_H,
                stroke:COLORS.bar,"stroke-width":"1",
              }));
            }

            // Chord name above bar
            if (doChords) {
              const chord = detectChord(bar, key);
              if (chord) {
                rowG.appendChild(txt(chord.roman, barStartX + barW/2, STAFF_TOP - 8, {
                  fill: COLORS.chord, size: 9, weight: "600",
                }));
              }
            }

            // Notes within bar
            const notesInBar = bar.filter(n => n.type === "note" || n.type === "rest");
            notesInBar.forEach((note, ni) => {
              const x = barStartX + (ni + 0.5) * (barW / Math.max(notesInBar.length, 1));

              if (note.type === "rest") {
                drawRest(rowG, x, clefName);
                return;
              }

              const { name, oct } = midiToNote(note.midi);
              const dp  = diatonicPos(name, oct);
              if (dp === null) return;

              const isAccid    = name.includes("#");
              const isLandmark = false; // simplified for jianpu display

              // Ledger lines
              drawLedgerLines(rowG, x, dp, clefName);

              // Notehead
              const ny = drawNotehead(rowG, x, dp, clefName, false, isAccid, isLandmark);

              // Stem + flags
              if (note.dur !== "whole") {
                const { stemUp, stemX, stemY } = drawStem(rowG, x, ny, dp, clefName);
                if (note.dur === "eighth")     drawFlag(rowG, stemX, stemY, stemUp, 1);
                if (note.dur === "sixteenth")  drawFlag(rowG, stemX, stemY, stemUp, 2);
              }

              // Sharp sign
              if (isAccid) {
                rowG.appendChild(el("text",{
                  x: x - SP*1.4, y: ny + 3,
                  fill: COLORS.acc, "font-size": SP*1.3,
                  "font-family":"serif","text-anchor":"middle",
                }, [document.createTextNode("♯")]));
              }

              // Note name
              if (doNames) {
                rowG.appendChild(txt(name.replace("#",""), x, ny + SP*0.45+3, {
                  size: 7, fill:"rgba(201,168,76,0.6)", weight:"500",
                }));
              }

              // Scale degree number below staff
              rowG.appendChild(txt(note.degree || "", x, REF_Y_IN_ROW + SP*1.8, {
                size: 8, fill:"rgba(248,245,238,0.3)",
              }));

              // Lyrics
              if (lyrics[lyricIdx]) {
                rowG.appendChild(txt(lyrics[lyricIdx], x, REF_Y_IN_ROW + SP*3.2, {
                  size: 9, fill: COLORS.lyrics,
                }));
              }
              lyricIdx++;
            });

            // Final bar line
            if (bi === rowBars.length - 1) {
              const ex = barEndX;
              rowG.appendChild(el("line",{
                x1:ex,y1:STAFF_TOP,x2:ex,y2:STAFF_TOP+STAFF_H,
                stroke:COLORS.bar,"stroke-width":"1.5",
              }));
            }
          });

          staffSvg.appendChild(rowG);
        }
      }

      // Show output
      emptyState.classList.add("hidden");
      outputCont.classList.remove("hidden");
      exportPng.classList.remove("hidden");
      exportPdf.classList.remove("hidden");
      outputInfo.textContent = `${bars.length} bars · ${key} major · ${timeSig}`;
    }

    // ── Export PNG ────────────────────────────────────────────────────────────
    exportPng.addEventListener("click", () => {
      const svgData  = new XMLSerializer().serializeToString(staffSvg);
      const svgBlob  = new Blob([svgData], {type:"image/svg+xml"});
      const url      = URL.createObjectURL(svgBlob);
      const img      = new Image();
      const scale    = 2;
      img.onload = () => {
        const canvas   = document.createElement("canvas");
        canvas.width   = staffSvg.getAttribute("width")  * scale;
        canvas.height  = staffSvg.getAttribute("height") * scale;
        const ctx      = canvas.getContext("2d");
        ctx.scale(scale, scale);
        ctx.drawImage(img, 0, 0);
        const a = document.createElement("a");
        a.href     = canvas.toDataURL("image/png");
        a.download = "jianpu-staff.png";
        a.click();
        URL.revokeObjectURL(url);
      };
      img.src = url;
    });

    // ── Export PDF ────────────────────────────────────────────────────────────
    exportPdf.addEventListener("click", () => {
      const svgData = new XMLSerializer().serializeToString(staffSvg);
      const w = window.open("","_blank");
      w.document.write(`
        <!DOCTYPE html><html><head>
        <title>Jianpu Staff Notation</title>
        <style>body{margin:20px;background:#fff;}svg{max-width:100%;}</style>
        </head><body>
        ${svgData}
        <script>window.onload=()=>{window.print();}<\/script>
        </body></html>`);
      w.document.close();
    });

    // ── Events ────────────────────────────────────────────────────────────────
    convertBtn.addEventListener("click", render);
    clearBtn.addEventListener("click", () => {
      inputEl.value = "";
      lyricsEl.value = "";
      emptyState.classList.remove("hidden");
      outputCont.classList.add("hidden");
      exportPng.classList.add("hidden");
      exportPdf.classList.add("hidden");
    });

    // Auto-convert on settings change if there's input
    [keyEl, timeEl, clefEl, barsRowEl, showChordsEl, showNamesEl].forEach(el => {
      el.addEventListener("change", () => { if (inputEl.value.trim()) render(); });
    });

    // Enter key in input converts
    inputEl.addEventListener("keydown", e => {
      if (e.key === "Enter" && e.ctrlKey) render();
    });

    // Load Noto Music font
    const font = new FontFace("Noto Music",
      "url(https://fonts.gstatic.com/s/notomusic/v20/W9S0n5kWhSfBQT0dEKByWg.woff2)");
    font.load().then(f => document.fonts.add(f)).catch(()=>{});

  })();
  </script>

</Layout>
