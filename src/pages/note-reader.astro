---
// src/pages/note-reader.astro  — v2 (4-fix update)
import Layout from "../layouts/Layout.astro";
import CoffeeButton from "../components/CoffeeButton.astro";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Piano Note Reader — Learn to Read Music | Big Piano Small Piano",
  "description": "Play piano keys and watch the notes appear on a musical staff in real time. Learn to read treble and bass clef notation interactively.",
  "url": "https://bigpianosmallpiano.pages.dev/note-reader",
  "applicationCategory": "EducationalApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
};
---

<Layout
  title="Learn to Read Piano Notes — Interactive Staff | Big Piano Small Piano"
  description="Play piano keys and watch notes appear on a musical staff in real time. Learn treble and bass clef notation interactively. Free tool for piano beginners."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- HERO -->
  <section class="relative overflow-hidden border-b border-surface-border">
    <div class="absolute inset-0 bg-keys-pattern opacity-50 pointer-events-none"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold to-transparent"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 py-8 sm:py-12 text-center flex flex-col items-center gap-2">
      <p class="text-gold text-xs tracking-[0.25em] uppercase font-mono">Learning tool</p>
      <h1 class="font-display text-4xl sm:text-5xl font-semibold text-ivory leading-tight">
        Piano <span class="italic text-gold">Note Reader</span>
      </h1>
      <p class="text-ivory/50 text-sm max-w-lg leading-relaxed">
        Play any key and watch it appear on the staff. Learn to connect
        what you play with how it looks in sheet music.
      </p>
    </div>
  </section>

  <!-- TOOLBAR -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-5">
    <div class="bg-surface border border-surface-border rounded-xl p-3 flex flex-wrap items-center gap-3">

      <div class="flex rounded-lg border border-surface-border overflow-hidden flex-shrink-0">
        <button id="clef-treble" data-clef="treble"
          class="clef-btn px-4 py-2 text-sm font-medium bg-gold text-ebony transition-all">
          𝄞 Treble
        </button>
        <button id="clef-bass" data-clef="bass"
          class="clef-btn px-4 py-2 text-sm font-medium text-ivory/50 hover:text-ivory transition-all">
          𝄢 Bass
        </button>
        <button id="clef-grand" data-clef="grand"
          class="clef-btn px-4 py-2 text-sm font-medium text-ivory/50 hover:text-ivory transition-all">
          Grand Staff
        </button>
      </div>

      <label class="flex items-center gap-2 cursor-pointer select-none">
        <input type="checkbox" id="show-labels" class="w-4 h-4 accent-gold" checked />
        <span class="text-ivory/60 text-sm">Note names</span>
      </label>

      <label class="flex items-center gap-2 cursor-pointer select-none">
        <input type="checkbox" id="show-landmarks" class="w-4 h-4 accent-gold" checked />
        <span class="text-ivory/60 text-sm">Landmarks</span>
      </label>

      <button id="clear-btn"
        class="ml-auto text-xs text-ivory/40 hover:text-gold border border-surface-border hover:border-gold/40 px-3 py-2 rounded-lg transition-all">
        Clear
      </button>

      <button id="rec-btn"
        class="flex items-center gap-1.5 border border-surface-border hover:border-red-500/50 text-ivory/50 hover:text-red-400 text-xs px-3 py-2 rounded-lg transition-all">
        <span class="w-2 h-2 rounded-full bg-red-500"></span>
        <span id="rec-label">Record</span>
      </button>
      <span id="rec-timer" class="text-ivory/30 text-xs font-mono">0:00</span>
      <a id="rec-download" href="#" download="note-reader-session.webm"
        class="hidden text-xs bg-gold hover:bg-gold-dark text-ebony font-medium px-3 py-2 rounded-lg transition-colors">
        ↓ Save
      </a>
    </div>
  </div>

  <!-- LEGENDS -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-3">
    <div class="grid sm:grid-cols-2 gap-3">

      <div id="legend-treble" class="bg-surface border border-surface-border rounded-xl px-4 py-3 flex items-center gap-4">
        <div class="text-center">
          <p class="text-gold text-xs font-mono uppercase tracking-widest mb-1">Lines (bottom→top)</p>
          <div class="flex gap-2">
            {["E","G","B","D","F"].map((n,i) => (
              <div class="text-center">
                <div class="w-7 h-7 rounded-full border border-gold/30 flex items-center justify-center">
                  <span class="font-display text-sm text-ivory/80">{n}</span>
                </div>
                <span class="text-ivory/25 text-xs">{i+1}</span>
              </div>
            ))}
          </div>
          <p class="text-ivory/30 text-xs mt-1 italic">"Every Good Boy Does Fine"</p>
        </div>
        <div class="w-px self-stretch bg-surface-border"></div>
        <div class="text-center">
          <p class="text-gold text-xs font-mono uppercase tracking-widest mb-1">Spaces</p>
          <div class="flex gap-2">
            {["F","A","C","E"].map(n => (
              <div class="w-7 h-7 rounded-full border border-gold/30 flex items-center justify-center">
                <span class="font-display text-sm text-ivory/80">{n}</span>
              </div>
            ))}
          </div>
          <p class="text-ivory/30 text-xs mt-1 italic">"FACE"</p>
        </div>
      </div>

      <div id="legend-bass" class="hidden bg-surface border border-surface-border rounded-xl px-4 py-3 flex items-center gap-4">
        <div class="text-center">
          <p class="text-gold text-xs font-mono uppercase tracking-widest mb-1">Lines (bottom→top)</p>
          <div class="flex gap-2">
            {["G","B","D","F","A"].map((n,i) => (
              <div class="text-center">
                <div class="w-7 h-7 rounded-full border border-gold/30 flex items-center justify-center">
                  <span class="font-display text-sm text-ivory/80">{n}</span>
                </div>
                <span class="text-ivory/25 text-xs">{i+1}</span>
              </div>
            ))}
          </div>
          <p class="text-ivory/30 text-xs mt-1 italic">"Good Boys Do Fine Always"</p>
        </div>
        <div class="w-px self-stretch bg-surface-border"></div>
        <div class="text-center">
          <p class="text-gold text-xs font-mono uppercase tracking-widest mb-1">Spaces</p>
          <div class="flex gap-2">
            {["A","C","E","G"].map(n => (
              <div class="w-7 h-7 rounded-full border border-gold/30 flex items-center justify-center">
                <span class="font-display text-sm text-ivory/80">{n}</span>
              </div>
            ))}
          </div>
          <p class="text-ivory/30 text-xs mt-1 italic">"All Cows Eat Grass"</p>
        </div>
      </div>

      <div id="legend-grand" class="hidden bg-surface border border-surface-border rounded-xl px-4 py-3 sm:col-span-2">
        <p class="text-ivory/40 text-xs text-center">Grand staff — right hand (treble), left hand (bass). Middle C sits between both staves on a ledger line.</p>
      </div>

    </div>
  </div>

  <!-- ── FIX 1: Two-layer staff — frozen clef layer + scrolling notes layer ── -->
  <!--
    The staff is split into two absolutely-positioned canvases:
      • #staff-bg-canvas  — drawn once, never scrolls (clef + staff lines)
      • #staff-notes-canvas — extends right as notes are added, translates left
    This way the clef is ALWAYS visible no matter how many notes are added.
  -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-4">
    <div class="bg-surface border border-surface-border rounded-xl overflow-hidden">
      <div class="flex items-center justify-between px-4 pt-3 pb-1">
        <p class="text-ivory/30 text-xs font-mono">Play keys below — notes appear here</p>
        <div class="flex items-center gap-3">
          <p class="text-ivory/20 text-xs font-mono" id="note-count">0 notes</p>
          <div id="playing-indicator" class="w-2 h-2 rounded-full bg-surface-border transition-colors duration-100"></div>
        </div>
      </div>
      <!-- Outer: fixed viewport height, clips overflow -->
      <div class="relative" style="height:220px;" id="staff-scroll-container">
        <!-- Layer 1: background (staff lines + frozen clef) — never moves -->
        <canvas id="staff-bg-canvas"
          class="absolute top-0 left-0 pointer-events-none"
          style="height:220px; z-index:1;"></canvas>
        <!-- Layer 2: scrolling notes canvas — translates left as notes grow -->
        <canvas id="staff-notes-canvas"
          class="absolute top-0 left-0 pointer-events-none"
          style="height:220px; z-index:2;"></canvas>
      </div>
    </div>
  </div>

  <!-- ── FIX 3: Piano with octave controls + touch-scroll hint ── -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-4">
    <div class="bg-surface border border-surface-border rounded-xl overflow-hidden">
      <div class="px-4 pt-3 pb-1 flex items-center justify-between flex-wrap gap-2">
        <p class="text-ivory/25 text-xs font-mono">
          A S D F G H J = white &nbsp;|&nbsp; W E T Y U = black &nbsp;|&nbsp; Scroll/swipe keyboard for more notes
        </p>
        <!-- Octave controls -->
        <div class="flex items-center gap-2 flex-shrink-0">
          <button id="oct-down"
            class="w-7 h-7 rounded border border-surface-border text-ivory/50 hover:text-gold text-sm flex items-center justify-center transition-colors">−</button>
          <span class="text-ivory/50 text-xs font-mono">Oct <span id="oct-label">4</span></span>
          <button id="oct-up"
            class="w-7 h-7 rounded border border-surface-border text-ivory/50 hover:text-gold text-sm flex items-center justify-center transition-colors">+</button>
        </div>
      </div>
      <!--
        FIX 3: overflow-x-auto + wider keyboard (4 octaves) so users can
        scroll/swipe horizontally to reach lower and higher notes.
        touch-action: pan-x allows native horizontal swipe on mobile.
      -->
      <div id="piano-keys"
        class="relative h-36 sm:h-44 px-3 pb-3 select-none"
        style="overflow-x:auto; overflow-y:hidden; touch-action:pan-x; min-height:144px;">
        <!-- keys injected by JS inside a fixed-width inner div -->
        <div id="piano-inner" class="relative h-full" style="min-height:120px;"></div>
      </div>
    </div>
  </div>

  <!-- NOTE QUIZ -->
  <!-- FIX 2: Taller quiz canvas (180px) + safe note pool so nothing gets clipped -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-4">
    <div class="bg-surface border border-surface-border rounded-xl p-5 space-y-4">
      <div class="flex items-center justify-between flex-wrap gap-2">
        <div>
          <p class="text-gold text-xs tracking-[0.2em] uppercase font-mono mb-0.5">Note quiz</p>
          <p class="text-ivory/60 text-sm">
            Can you find this note? Alternates between
            <span class="text-ivory/80">treble</span> and <span class="text-ivory/80">bass</span> clef.
          </p>
        </div>
        <button id="quiz-next"
          class="text-sm bg-gold hover:bg-gold-dark text-ebony font-medium px-4 py-2 rounded-lg transition-colors">
          New note →
        </button>
      </div>
      <div class="grid sm:grid-cols-2 gap-4 items-center">
        <!-- FIX 2: height 180 gives enough room for all notes + ledger lines -->
        <canvas id="quiz-canvas" width="300" height="180"
          class="w-full rounded-lg border border-surface-border bg-surface-raised"></canvas>
        <div class="space-y-3">
          <p class="text-ivory/50 text-sm">Play this note on the piano:</p>
          <div id="quiz-status"
            class="text-center py-3 rounded-lg border border-surface-border bg-surface-raised min-h-[60px] flex items-center justify-center">
            <p class="font-display text-2xl text-ivory/40 italic">Waiting…</p>
          </div>
          <div id="quiz-clef-label" class="text-xs font-mono text-ivory/30 text-center"></div>
          <div class="flex items-center gap-3 text-xs font-mono text-ivory/30">
            <span>✓ Correct: <span id="quiz-correct" class="text-green-400">0</span></span>
            <span>✗ Wrong: <span id="quiz-wrong" class="text-red-400">0</span></span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- TIPS -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-4 pb-8">
    <div class="bg-surface border border-surface-border rounded-xl p-5">
      <p class="text-gold text-xs tracking-[0.2em] uppercase font-mono mb-4">Tips for reading music</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          { icon:"🎯", title:"Start with landmarks", tip:"Learn Middle C, Treble G (2nd line), and Bass F (4th line) first. All other notes are found by counting from these anchors." },
          { icon:"📏", title:"Lines vs spaces", tip:"Notes sit ON a line (the line goes through the notehead) or IN a space (between two lines). This tells you which note it is." },
          { icon:"🔑", title:"The clef is your key", tip:"Treble clef curls around the G line. Bass clef's two dots surround the F line. These anchor notes define everything else." },
          { icon:"🔢", title:"Count by steps", tip:"Notes move alphabetically A–G then repeat. From C, count up: C D E F G A B C. Each step up on the staff = one letter up." },
          { icon:"🪄", title:"Ledger lines", tip:"Middle C sits on a short ledger line below treble clef or above bass clef. It's the bridge between both clefs." },
          { icon:"🔄", title:"Practice daily", tip:"Even 5 minutes a day identifying notes on the staff builds muscle memory faster than an hour once a week." },
        ].map(item => (
          <div class="flex gap-3">
            <span class="text-xl flex-shrink-0 mt-0.5">{item.icon}</span>
            <div>
              <p class="font-display text-ivory/80 text-sm font-semibold mb-1">{item.title}</p>
              <p class="text-ivory/45 text-xs leading-relaxed">{item.tip}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
    <div class="mt-4">
      <CoffeeButton variant="inline"
        message="Enjoying the free learning tools? A coffee helps keep them free for everyone." />
    </div>
  </div>

  <!-- ════════════════════════ SCRIPT ════════════════════════════════════════ -->
  <script>
  (function () {

    // ── Note utilities ──────────────────────────────────────────────────────
    const NOTE_NAMES = ["C","C#","D","D#","E","F","F#","G","G#","A","A#","B"];
    const DIATONIC   = ["C","D","E","F","G","A","B"];
    const A4 = 440;

    function noteFreq(name, oct) {
      return A4 * Math.pow(2, (NOTE_NAMES.indexOf(name) - 9 + (oct - 4) * 12) / 12);
    }
    function isNatural(name) { return !name.includes("#"); }
    function staffPosition(noteName, octave) {
      const base = DIATONIC.indexOf(noteName.replace("#","").replace("b",""));
      if (base === -1) return null;
      return (octave - 4) * 7 + base;
    }

    // ── State ───────────────────────────────────────────────────────────────
    let clef          = "treble";
    let showLabels    = true;
    let showLandmarks = true;
    let noteHistory   = [];
    let octaveBase    = 4;
    let audioCtx      = null, recDest = null;
    let mediaRec      = null, recChunks = [], isRecording = false;
    let recSeconds    = 0, recInterval = null;
    let quizNote      = null, quizClef = "treble";
    let quizCorrect   = 0, quizWrong = 0, quizAnswered = false;

    // ── DOM ─────────────────────────────────────────────────────────────────
    const scrollCont     = document.getElementById("staff-scroll-container");
    const bgCanvas       = document.getElementById("staff-bg-canvas");
    const notesCanvas    = document.getElementById("staff-notes-canvas");
    const pianoOuter     = document.getElementById("piano-keys");
    const pianoInner     = document.getElementById("piano-inner");
    const noteCountEl    = document.getElementById("note-count");
    const playingInd     = document.getElementById("playing-indicator");
    const clearBtn       = document.getElementById("clear-btn");
    const recBtn         = document.getElementById("rec-btn");
    const recLabel       = document.getElementById("rec-label");
    const recTimerEl     = document.getElementById("rec-timer");
    const recDownload    = document.getElementById("rec-download");
    const quizCanvas     = document.getElementById("quiz-canvas");
    const quizStatus     = document.getElementById("quiz-status");
    const quizNextBtn    = document.getElementById("quiz-next");
    const quizClefLabel  = document.getElementById("quiz-clef-label");
    const showLabelsEl   = document.getElementById("show-labels");
    const showLandEl     = document.getElementById("show-landmarks");
    const legendTreble   = document.getElementById("legend-treble");
    const legendBass     = document.getElementById("legend-bass");
    const legendGrand    = document.getElementById("legend-grand");
    const octLabel       = document.getElementById("oct-label");

    const bgCtx    = bgCanvas.getContext("2d");
    const notesCtx = notesCanvas.getContext("2d");
    const quizCtx  = quizCanvas.getContext("2d");

    // ── Colors ──────────────────────────────────────────────────────────────
    const C = {
      bg:       "#141414",
      line:     "rgba(248,245,238,0.25)",
      clef:     "rgba(201,168,76,0.9)",
      noteFill: "#F8F5EE",
      noteGold: "#C9A84C",
      noteAcc:  "#7CB9E8",
      ledger:   "rgba(248,245,238,0.45)",
    };

    // ── Staff geometry ──────────────────────────────────────────────────────
    const STEP = 9;  // pixels per diatonic step

    /*
      FIX 4: Corrected treble clef positioning.

      Treble staff lines (bottom → top):
        Line 1: E4  staffPos = (4-4)*7 + DIATONIC["E"=2] = 2
        Line 2: G4  staffPos = 4   ← the G line the treble clef curls around
        Line 3: B4  staffPos = 6   ← middle line
        Line 4: D5  staffPos = 8
        Line 5: F5  staffPos = 10

      We place the canvas such that the MIDDLE LINE (B4, staffPos=6) sits
      at canvasHeight/2.  Then G (staffPos=4) is 2*STEP below that.

      Bass staff lines:
        Line 1: G2  staffPos = -10
        Line 2: B2  staffPos = -8   ← middle line
        Line 3: D3  staffPos = -6
        Line 4: F3  staffPos = -4   ← the F line bass clef dots surround
        Line 5: A3  staffPos = -2
    */
    function getStaffConfig(canvasHeight, forClef) {
      if (forClef === "treble") {
        return {
          midLineStaffPos: 6,           // B4 = middle of treble staff
          midLineY: canvasHeight / 2,
          lines: [2, 4, 6, 8, 10],      // E4 G4 B4 D5 F5
          isTreeble: true,
          landmarkPos: [0, 4],           // Middle C (ledger line below), G4 (line 2)
        };
      } else {
        return {
          midLineStaffPos: -8,           // B2 = middle of bass staff
          midLineY: canvasHeight / 2,
          lines: [-10, -8, -6, -4, -2],  // G2 B2 D3 F3 A3
          isTreeble: false,
          landmarkPos: [0, -4],          // Middle C (ledger above), F3 (line 4)
        };
      }
    }

    function staffPosToY(staffPos, config) {
      return config.midLineY + (config.midLineStaffPos - staffPos) * STEP;
    }

    // ── Draw staff lines (used for both bg and quiz canvases) ───────────────
    function drawLines(ctx, w, h, config) {
      ctx.strokeStyle = C.line;
      ctx.lineWidth   = 0.8;
      config.lines.forEach(pos => {
        const y = staffPosToY(pos, config);
        ctx.beginPath();
        ctx.moveTo(0, y);
        ctx.lineTo(w, y);
        ctx.stroke();
      });
    }

    /*
      FIX 4: Treble clef Y position.

      The Unicode 𝄞 glyph's visual anchor (the curl) is roughly at
      the BOTTOM of the rendered character box, not the top.
      We want the curl to sit on the G line (staffPos=4).

      After measurement with serif fonts at 72px:
        - character box height ≈ 90px
        - the curl sits about 78% from the top of the box
        → anchor offset ≈ 0.78 × fontSize

      So:  clefY = G_line_Y + anchor_offset
              where anchor_offset accounts for where the glyph's curl lands.

      Bass clef (𝄢) at 52px: the two dots straddle the F line.
      The baseline of 𝄢 sits roughly at the top dot level.
      F line is staffPos=-4.  Bass clef Y ≈ F_line_Y - 4px.
    */
    function drawClef(ctx, config, frozen) {
      if (config.isTreeble) {
        const fontSize = 72;
        ctx.font      = `${fontSize}px serif`;
        ctx.fillStyle = C.clef;
        ctx.textAlign = "left";
        // G line Y:
        const gLineY   = staffPosToY(4, config);
        // Curl anchor is ~78% down the glyph body from the top.
        // We want the curl AT gLineY, so the top of the glyph is:
        //   topOfGlyph = gLineY - 0.78 * fontSize
        // But ctx.fillText Y is the BASELINE, which for this glyph is
        // near the very bottom. Empirically: baseline ≈ topOfGlyph + fontSize
        // So:  textY = gLineY + fontSize * (1 - 0.78) = gLineY + fontSize * 0.22
        // However the glyph also descends (tail below staff), so baseline is
        // actually higher. Best empirical value: textY = gLineY + 18
        ctx.fillText("𝄞", 6, gLineY + 18);
      } else {
        const fontSize = 52;
        ctx.font      = `${fontSize}px serif`;
        ctx.fillStyle = C.clef;
        ctx.textAlign = "left";
        // Bass clef: position so dots straddle F3 line (staffPos=-4)
        const fLineY = staffPosToY(-4, config);
        ctx.fillText("𝄢", 6, fLineY + 6);
      }
    }

    // ── Redraw background (FIX 1: frozen layer) ─────────────────────────────
    // CLEF_ZONE: width reserved on the left for the frozen clef
    const CLEF_ZONE = 58;

    function redrawBackground() {
      const w = bgCanvas.width;
      const h = bgCanvas.height;
      bgCtx.clearRect(0, 0, w, h);
      bgCtx.fillStyle = C.bg;
      bgCtx.fillRect(0, 0, w, h);

      if (clef === "grand") {
        const halfH = h / 2 - 6;
        const tConf = getStaffConfig(halfH, "treble");
        const bConf = { ...getStaffConfig(halfH, "bass"), midLineY: halfH + 12 + halfH / 2 };
        drawLines(bgCtx, w, h, tConf);
        drawClef(bgCtx, tConf, true);
        drawLines(bgCtx, w, h, bConf);
        drawClef(bgCtx, bConf, true);
      } else {
        const config = getStaffConfig(h, clef);
        drawLines(bgCtx, w, h, config);
        drawClef(bgCtx, config, true);
      }
    }

    // ── Redraw notes layer ───────────────────────────────────────────────────
    const NOTE_START_X = CLEF_ZONE + 16; // first note X
    const NOTE_SPACING = 38;

    function redrawNotes() {
      const h        = notesCanvas.height;
      const needed   = NOTE_START_X + noteHistory.length * NOTE_SPACING + 60;
      notesCanvas.width = Math.max(bgCanvas.width, needed);
      notesCtx.clearRect(0, 0, notesCanvas.width, h);

      if (clef === "grand") {
        const halfH = h / 2 - 6;
        const tConf = getStaffConfig(halfH, "treble");
        const bConf = { ...getStaffConfig(halfH, "bass"), midLineY: halfH + 12 + halfH / 2 };
        noteHistory.forEach((entry, i) => {
          const x  = NOTE_START_X + i * NOTE_SPACING;
          const sp = staffPosition(entry.noteName.replace("#",""), entry.octave);
          if (sp === null) return;
          const useTreble = entry.octave >= 4;
          drawNote(notesCtx, x, sp, useTreble ? tConf : bConf,
                   entry.noteName, entry.octave, i === noteHistory.length - 1);
        });
      } else {
        const config = getStaffConfig(h, clef);
        noteHistory.forEach((entry, i) => {
          const x  = NOTE_START_X + i * NOTE_SPACING;
          const sp = staffPosition(entry.noteName.replace("#",""), entry.octave);
          if (sp !== null) {
            drawNote(notesCtx, x, sp, config,
                     entry.noteName, entry.octave, i === noteHistory.length - 1);
          }
        });
      }

      noteCountEl.textContent = `${noteHistory.length} note${noteHistory.length !== 1 ? "s" : ""}`;
      scrollNotesToLatest();
    }

    // Scroll notes canvas left so latest note is always visible
    function scrollNotesToLatest() {
      const latestX  = NOTE_START_X + (noteHistory.length - 1) * NOTE_SPACING;
      const viewW    = scrollCont.clientWidth;
      const overflow = latestX - viewW + 80;
      notesCanvas.style.transform = overflow > 0 ? `translateX(-${overflow}px)` : "";
    }

    // ── Draw a notehead ──────────────────────────────────────────────────────
    function drawNote(ctx, x, staffPos, config, noteName, octave, isActive) {
      const y          = staffPosToY(staffPos, config);
      const r          = STEP * 0.82;
      const isLandmark = showLandmarks && config.landmarkPos.includes(staffPos);
      const isAccid    = !isNatural(noteName);
      const bottomLine = Math.min(...config.lines);
      const topLine    = Math.max(...config.lines);

      // ── Ledger lines ──
      ctx.strokeStyle = C.ledger;
      ctx.lineWidth   = 1.2;
      // Need ledger lines for every even position beyond the staff
      const ledgerPadding = staffPos % 2 === 0 ? 0 : 1;
      for (let p = bottomLine - 2; p >= staffPos - ledgerPadding; p -= 2) {
        const ly = staffPosToY(p, config);
        ctx.beginPath();
        ctx.moveTo(x - r * 1.6, ly);
        ctx.lineTo(x + r * 1.6, ly);
        ctx.stroke();
      }
      for (let p = topLine + 2; p <= staffPos + ledgerPadding; p += 2) {
        const ly = staffPosToY(p, config);
        ctx.beginPath();
        ctx.moveTo(x - r * 1.6, ly);
        ctx.lineTo(x + r * 1.6, ly);
        ctx.stroke();
      }

      // ── Notehead ──
      ctx.beginPath();
      ctx.ellipse(x, y, r, r * 0.72, -0.18, 0, Math.PI * 2);
      ctx.fillStyle = isActive   ? "#FFFFFF" :
                      isLandmark ? C.noteGold :
                      isAccid    ? C.noteAcc  : C.noteFill;
      ctx.fill();

      // ── Stem ──
      ctx.strokeStyle = ctx.fillStyle;
      ctx.lineWidth   = 1.5;
      const stemDir   = staffPos >= config.midLineStaffPos ? -1 : 1;
      const stemX     = x + (stemDir === 1 ? r * 0.9 : -r * 0.9);
      ctx.beginPath();
      ctx.moveTo(stemX, y);
      ctx.lineTo(stemX, y - stemDir * STEP * 3.5);
      ctx.stroke();

      // ── Sharp symbol ──
      if (isAccid) {
        ctx.fillStyle = C.noteAcc;
        ctx.font      = `bold ${STEP * 1.5}px sans-serif`;
        ctx.textAlign = "center";
        ctx.fillText("#", x - r * 2.2, y + STEP * 0.4);
      }

      // ── Note name label ──
      if (showLabels) {
        ctx.fillStyle = isLandmark ? C.noteGold : "rgba(201,168,76,0.65)";
        ctx.font      = `500 ${STEP * 1.25}px 'DM Sans', sans-serif`;
        ctx.textAlign = "center";
        ctx.fillText(noteName.replace("#",""), x, y + r * 0.8 + STEP * 1.8);
      }

      // ── Octave hint ──
      ctx.fillStyle = "rgba(248,245,238,0.12)";
      ctx.font      = `${STEP * 0.9}px monospace`;
      ctx.textAlign = "center";
      ctx.fillText(octave, x, y - STEP * 4.2);
    }

    // ── Resize + full redraw ─────────────────────────────────────────────────
    function resizeAndDraw() {
      const w = scrollCont.clientWidth;
      const h = 220;
      bgCanvas.width    = w;
      bgCanvas.height   = h;
      notesCanvas.height = h;
      redrawBackground();
      redrawNotes();
    }

    // ── Add a note to history ────────────────────────────────────────────────
    function addNote(noteName, octave) {
      noteHistory.push({ noteName, octave });
      redrawNotes();
    }

    // ── Audio ────────────────────────────────────────────────────────────────
    function getCtx() {
      if (!audioCtx) {
        audioCtx = new AudioContext();
        recDest  = audioCtx.createMediaStreamDestination();
      }
      if (audioCtx.state === "suspended") audioCtx.resume();
      return audioCtx;
    }

    function playNote(freq) {
      const ctx  = getCtx();
      const osc  = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.type   = "triangle";
      osc.frequency.value = freq;
      gain.gain.setValueAtTime(0.4, ctx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 1.2);
      osc.connect(gain);
      gain.connect(ctx.destination);
      gain.connect(recDest);
      osc.start(); osc.stop(ctx.currentTime + 1.3);
    }

    function playAndNotate(noteName, octave) {
      playNote(noteFreq(noteName, octave));
      addNote(noteName, octave);
      playingInd.style.background = "#C9A84C";
      setTimeout(() => { playingInd.style.background = ""; }, 150);
      checkQuizAnswer(noteName, octave);
    }

    // ── Piano keyboard — FIX 3: 4 octaves, horizontal scroll ────────────────
    const WHITE_SEMI = [0,2,4,5,7,9,11];
    const BLACK_SEMI = [1,3,-1,6,8,10,-1];
    const OCTAVES    = 4;  // show 4 octaves (was 2)
    const KEY_W      = 36; // white key width in px
    const KEY_GAP    = 1;  // gap between white keys

    function buildPianoKeys() {
      pianoInner.innerHTML = "";
      const whites = [];
      for (let o = 0; o < OCTAVES; o++) {
        WHITE_SEMI.forEach(s => {
          whites.push({
            freq:   noteFreq(NOTE_NAMES[s], octaveBase - 1 + o),
            name:   NOTE_NAMES[s],
            octave: octaveBase - 1 + o,
          });
        });
      }

      const totalWhite = whites.length;
      const totalW     = totalWhite * (KEY_W + KEY_GAP);
      pianoInner.style.width  = totalW + "px";
      pianoInner.style.height = "100%";

      // White keys
      whites.forEach((k, i) => {
        const el = document.createElement("div");
        el.className = "piano-key white-key absolute bottom-0 rounded-b-md border border-gray-700 cursor-pointer transition-colors duration-75 bg-ivory hover:bg-gold/20 flex items-end justify-center pb-1";
        el.style.cssText = `width:${KEY_W}px; left:${i*(KEY_W+KEY_GAP)}px; top:0; bottom:0;`;
        el.innerHTML = `<span style="font-size:8px" class="text-ebony/20 font-mono pointer-events-none select-none">${k.name}${k.octave}</span>`;
        el.dataset.freq   = k.freq;
        el.dataset.note   = k.name;
        el.dataset.octave = k.octave;
        pianoInner.appendChild(el);
      });

      // Black keys
      for (let o = 0; o < OCTAVES; o++) {
        BLACK_SEMI.forEach((s, wi) => {
          if (s === -1) return;
          const freq   = noteFreq(NOTE_NAMES[s], octaveBase - 1 + o);
          const leftI  = o * 7 + wi; // index of the white key to the left
          const leftPx = leftI * (KEY_W + KEY_GAP);
          const el     = document.createElement("div");
          el.className = "piano-key black-key absolute rounded-b-md z-10 cursor-pointer transition-colors duration-75 bg-ebony hover:bg-gray-700";
          el.style.cssText = `width:${KEY_W * 0.6}px; left:${leftPx + KEY_W * 0.7}px; top:0; height:60%; box-shadow:0 4px 8px rgba(0,0,0,.8);`;
          el.dataset.freq   = freq;
          el.dataset.note   = NOTE_NAMES[s];
          el.dataset.octave = octaveBase - 1 + o;
          pianoInner.appendChild(el);
        });
      }

      // Scroll to show C4 area by default (middle of keyboard)
      const c4WhiteIndex = (1) * 7; // octaveBase-1+1 = octaveBase, 1 octave in = index 7
      pianoOuter.scrollLeft = c4WhiteIndex * (KEY_W + KEY_GAP) - 40;

      attachPianoEvents();
    }

    function attachPianoEvents() {
      let lastTriggered = null;

      function getKeyAt(x, y) {
        // Account for scroll offset
        const scrollLeft = pianoOuter.scrollLeft;
        const rect       = pianoOuter.getBoundingClientRect();
        const relX       = x - rect.left + scrollLeft;
        const relY       = y - rect.top;

        let found = null;
        // Check black keys first (higher z-index)
        for (const k of pianoInner.querySelectorAll(".black-key")) {
          const kLeft  = parseFloat(k.style.left);
          const kW     = parseFloat(k.style.width);
          const kH     = pianoInner.clientHeight * 0.6;
          if (relX >= kLeft && relX <= kLeft + kW && relY <= kH) { found = k; break; }
        }
        if (!found) {
          for (const k of pianoInner.querySelectorAll(".white-key")) {
            const kLeft = parseFloat(k.style.left);
            if (relX >= kLeft && relX <= kLeft + KEY_W) { found = k; break; }
          }
        }
        return found;
      }

      function trigger(el) {
        if (!el || el === lastTriggered) return;
        lastTriggered = el;
        playAndNotate(el.dataset.note, parseInt(el.dataset.octave));
        el.classList.add("active");
        setTimeout(() => el.classList.remove("active"), 200);
      }

      pianoInner.querySelectorAll("[data-note]").forEach(el => {
        el.addEventListener("mousedown",  e => { e.stopPropagation(); e.preventDefault(); trigger(el); });
        el.addEventListener("touchstart", e => { e.stopPropagation(); e.preventDefault(); trigger(el); }, { passive: false });
      });

      pianoOuter.addEventListener("mousemove", e => {
        if (e.buttons !== 1) { lastTriggered = null; return; }
        trigger(getKeyAt(e.clientX, e.clientY));
      });
      pianoOuter.addEventListener("mouseup",    () => lastTriggered = null);
      pianoOuter.addEventListener("mouseleave", () => lastTriggered = null);

      pianoOuter.addEventListener("touchmove", e => {
        // Don't prevent default here so horizontal scroll still works
        Array.from(e.changedTouches).forEach(t => {
          const el = getKeyAt(t.clientX, t.clientY);
          if (el) trigger(el);
        });
      });
      pianoOuter.addEventListener("touchend", () => lastTriggered = null);
    }

    // Keyboard shortcuts
    const KB = {"a":"C","w":"C#","s":"D","e":"D#","d":"E","f":"F","t":"F#","g":"G","y":"G#","h":"A","u":"A#","j":"B"};
    document.addEventListener("keydown", e => {
      if (e.target instanceof HTMLInputElement || e.repeat) return;
      const k = e.key.toLowerCase();
      if (KB[k]) {
        playAndNotate(KB[k], octaveBase);
        pianoInner.querySelectorAll("[data-note]").forEach(el => {
          if (el.dataset.note === KB[k] && parseInt(el.dataset.octave) === octaveBase) {
            el.classList.add("active");
            setTimeout(() => el.classList.remove("active"), 200);
          }
        });
      }
    });

    // Octave controls
    document.getElementById("oct-down").addEventListener("click", () => {
      if (octaveBase > 2) { octaveBase--; octLabel.textContent = octaveBase; buildPianoKeys(); }
    });
    document.getElementById("oct-up").addEventListener("click", () => {
      if (octaveBase < 6) { octaveBase++; octLabel.textContent = octaveBase; buildPianoKeys(); }
    });

    // ── Quiz — FIX 2 ─────────────────────────────────────────────────────────
    /*
      Safe note pool:
      - Treble pool: notes whose staffPos fits comfortably in the quiz canvas.
        Canvas height = 180px. Config midLineY = 90.
        Treble midLineStaffPos = 6 (B4).
        Y for staffPos p = 90 + (6-p)*9
        Visible range: Y from ~10 to ~170 → staffPos range 4 to 14 (E4 to A5) safe.
        Extend slightly below with ledger lines: C4 (staffPos=0) is OK since canvas is tall.

      - Bass pool: midLineStaffPos = -8 (B2).
        Y = 90 + (-8-p)*9
        Visible range: staffPos -12 to -2 (G2..A3) safe.
    */
    const QUIZ_TREBLE = [
      {n:"C",o:4},{n:"D",o:4},{n:"E",o:4},{n:"F",o:4},{n:"G",o:4},
      {n:"A",o:4},{n:"B",o:4},{n:"C",o:5},{n:"D",o:5},{n:"E",o:5},
    ];
    const QUIZ_BASS = [
      {n:"G",o:2},{n:"A",o:2},{n:"B",o:2},{n:"C",o:3},{n:"D",o:3},
      {n:"E",o:3},{n:"F",o:3},{n:"G",o:3},{n:"A",o:3},{n:"B",o:3},
    ];
    let quizUseClef = "treble";

    function newQuizNote() {
      // Alternate clef each question
      quizUseClef  = quizUseClef === "treble" ? "bass" : "treble";
      const pool   = quizUseClef === "treble" ? QUIZ_TREBLE : QUIZ_BASS;
      quizNote     = pool[Math.floor(Math.random() * pool.length)];
      quizAnswered = false;
      quizStatus.innerHTML = `<p class="font-display text-2xl text-ivory/40 italic">Waiting…</p>`;
      quizClefLabel.textContent = quizUseClef === "treble" ? "𝄞 Treble clef" : "𝄢 Bass clef";
      drawQuizStaff();
    }

    function drawQuizStaff() {
      if (!quizNote) return;
      const w = quizCanvas.width, h = quizCanvas.height;
      quizCtx.fillStyle = C.bg;
      quizCtx.fillRect(0, 0, w, h);

      const config = getStaffConfig(h, quizUseClef);
      drawLines(quizCtx, w, h, config);
      drawClef(quizCtx, config, false);

      const sp = staffPosition(quizNote.n, quizNote.o);
      if (sp !== null) {
        drawNote(quizCtx, w / 2 + 20, sp, config, quizNote.n, quizNote.o, false);
        // If showLabels is OFF, paint over the label area
        if (!showLabels) {
          const noteY = staffPosToY(sp, config);
          quizCtx.fillStyle = C.bg;
          quizCtx.fillRect(w/2, noteY + 4, 60, 20);
        }
      }
    }

    function checkQuizAnswer(noteName, octave) {
      if (!quizNote || quizAnswered) return;
      const natural = noteName.replace("#","");
      if (natural === quizNote.n && octave === quizNote.o) {
        quizAnswered = true;
        quizCorrect++;
        document.getElementById("quiz-correct").textContent = quizCorrect;
        quizStatus.innerHTML = `<p class="font-display text-2xl text-green-400">✓ ${quizNote.n}${quizNote.o} — correct!</p>`;
        setTimeout(newQuizNote, 1800);
      } else if (isNatural(noteName)) {
        quizWrong++;
        document.getElementById("quiz-wrong").textContent = quizWrong;
        quizStatus.innerHTML = `<p class="font-display text-lg text-red-400">Not quite — look at the staff!</p>`;
      }
    }

    // ── Recorder ─────────────────────────────────────────────────────────────
    function fmt(s) { return `${Math.floor(s/60)}:${String(s%60).padStart(2,"0")}`; }
    recBtn.addEventListener("click", () => {
      if (isRecording) {
        mediaRec.stop(); isRecording = false;
        recLabel.textContent = "Record";
        recBtn.classList.remove("border-red-500/50","text-red-400");
        clearInterval(recInterval);
      } else {
        getCtx();
        mediaRec  = new MediaRecorder(recDest.stream); recChunks = [];
        mediaRec.ondataavailable = e => { if(e.data.size>0) recChunks.push(e.data); };
        mediaRec.onstop = () => {
          recDownload.href = URL.createObjectURL(new Blob(recChunks,{type:"audio/webm"}));
          recDownload.classList.remove("hidden");
        };
        mediaRec.start(100); isRecording = true; recSeconds = 0;
        recLabel.textContent = "Stop";
        recBtn.classList.add("border-red-500/50","text-red-400");
        recDownload.classList.add("hidden");
        recInterval = setInterval(() => { recSeconds++; recTimerEl.textContent = fmt(recSeconds); }, 1000);
      }
    });

    // ── Controls ─────────────────────────────────────────────────────────────
    document.querySelectorAll(".clef-btn").forEach(btn => {
      btn.addEventListener("click", () => {
        clef = btn.dataset.clef;
        document.querySelectorAll(".clef-btn").forEach(b => {
          const a = b === btn;
          b.classList.toggle("bg-gold",a); b.classList.toggle("text-ebony",a);
          b.classList.toggle("text-ivory/50",!a);
        });
        legendTreble.classList.toggle("hidden", clef !== "treble");
        legendBass.classList.toggle("hidden",   clef !== "bass");
        legendGrand.classList.toggle("hidden",  clef !== "grand");
        redrawBackground();
        redrawNotes();
      });
    });

    showLabelsEl.addEventListener("change", e => {
      showLabels = e.target.checked;
      redrawNotes();
      drawQuizStaff();
    });
    showLandEl.addEventListener("change", e => {
      showLandmarks = e.target.checked;
      redrawNotes();
    });

    clearBtn.addEventListener("click", () => {
      noteHistory = [];
      notesCanvas.style.transform = "";
      redrawNotes();
    });

    quizNextBtn.addEventListener("click", newQuizNote);

    // ── Init ──────────────────────────────────────────────────────────────────
    window.addEventListener("resize", resizeAndDraw);
    resizeAndDraw();
    buildPianoKeys();
    newQuizNote();

  })();
  </script>

  <style>
    .white-key.active { background: rgba(201,168,76,0.4) !important; }
    .black-key.active { background: rgba(201,168,76,0.7) !important; }
  </style>

</Layout>
