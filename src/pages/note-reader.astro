---
// src/pages/note-reader.astro — v4 (VexFlow clefs)
import Layout from "../layouts/Layout.astro";
import CoffeeButton from "../components/CoffeeButton.astro";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Piano Note Reader — Learn to Read Music | Big Piano Small Piano",
  "description": "Play piano keys and watch the notes appear on a musical staff in real time. Learn treble and bass clef notation interactively.",
  "url": "https://bigpianosmallpiano.pages.dev/note-reader",
  "applicationCategory": "EducationalApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
};
---

<Layout
  title="Learn to Read Piano Notes — Interactive Staff | Big Piano Small Piano"
  description="Play piano keys and watch notes appear on a musical staff in real time. Learn treble and bass clef notation interactively. Free tool for piano beginners."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- VexFlow — industry-standard music notation library -->
  <script src="https://cdn.jsdelivr.net/npm/vexflow@4.2.2/build/cjs/vexflow.js"></script>

  <!-- HERO -->
  <section class="relative overflow-hidden border-b border-surface-border">
    <div class="absolute inset-0 bg-keys-pattern opacity-50 pointer-events-none"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold to-transparent"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 py-8 sm:py-12 text-center flex flex-col items-center gap-2">
      <p class="text-gold text-xs tracking-[0.25em] uppercase font-mono">Learning tool</p>
      <h1 class="font-display text-4xl sm:text-5xl font-semibold text-ivory leading-tight">
        Piano <span class="italic text-gold">Note Reader</span>
      </h1>
      <p class="text-ivory/50 text-sm max-w-lg leading-relaxed">
        Play any key and watch it appear on the staff. Learn to connect
        what you play with how it looks in sheet music.
      </p>
    </div>
  </section>

  <!-- TOOLBAR -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-5">
    <div class="bg-surface border border-surface-border rounded-xl p-3 flex flex-wrap items-center gap-3">

      <div class="flex rounded-lg border border-surface-border overflow-hidden flex-shrink-0">
        <button id="clef-treble" data-clef="treble"
          class="clef-btn px-5 py-2 text-sm font-medium bg-gold text-ebony transition-all">
          𝄞 Treble
        </button>
        <button id="clef-bass" data-clef="bass"
          class="clef-btn px-5 py-2 text-sm font-medium text-ivory/50 hover:text-ivory transition-all">
          𝄢 Bass
        </button>
      </div>

      <label class="flex items-center gap-2 cursor-pointer select-none">
        <input type="checkbox" id="show-labels" class="w-4 h-4 accent-gold" checked />
        <span class="text-ivory/60 text-sm">Note names</span>
      </label>

      <label class="flex items-center gap-2 cursor-pointer select-none">
        <input type="checkbox" id="show-landmarks" class="w-4 h-4 accent-gold" checked />
        <span class="text-ivory/60 text-sm">Landmarks</span>
      </label>

      <button id="clear-btn"
        class="ml-auto text-xs text-ivory/40 hover:text-gold border border-surface-border hover:border-gold/40 px-3 py-2 rounded-lg transition-all">
        Clear
      </button>

      <button id="rec-btn"
        class="flex items-center gap-1.5 border border-surface-border hover:border-red-500/50 text-ivory/50 hover:text-red-400 text-xs px-3 py-2 rounded-lg transition-all">
        <span class="w-2 h-2 rounded-full bg-red-500"></span>
        <span id="rec-label">Record</span>
      </button>
      <span id="rec-timer" class="text-ivory/30 text-xs font-mono">0:00</span>
      <a id="rec-download" href="#" download="note-reader.webm"
        class="hidden text-xs bg-gold hover:bg-gold-dark text-ebony font-medium px-3 py-2 rounded-lg transition-colors">
        ↓ Save
      </a>
    </div>
  </div>

  <!-- LEGENDS -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-3">
    <div class="grid sm:grid-cols-2 gap-3">
      <div id="legend-treble" class="bg-surface border border-surface-border rounded-xl px-4 py-3 flex items-center gap-4">
        <div class="text-center">
          <p class="text-gold text-xs font-mono uppercase tracking-widest mb-1">Lines (bottom→top)</p>
          <div class="flex gap-2">
            {["E","G","B","D","F"].map((n,i) => (
              <div class="text-center">
                <div class="w-7 h-7 rounded-full border border-gold/30 flex items-center justify-center">
                  <span class="font-display text-sm text-ivory/80">{n}</span>
                </div>
                <span class="text-ivory/25 text-xs">{i+1}</span>
              </div>
            ))}
          </div>
          <p class="text-ivory/30 text-xs mt-1 italic">"Every Good Boy Does Fine"</p>
        </div>
        <div class="w-px self-stretch bg-surface-border"></div>
        <div class="text-center">
          <p class="text-gold text-xs font-mono uppercase tracking-widest mb-1">Spaces</p>
          <div class="flex gap-2">
            {["F","A","C","E"].map(n => (
              <div class="w-7 h-7 rounded-full border border-gold/30 flex items-center justify-center">
                <span class="font-display text-sm text-ivory/80">{n}</span>
              </div>
            ))}
          </div>
          <p class="text-ivory/30 text-xs mt-1 italic">"FACE"</p>
        </div>
      </div>

      <div id="legend-bass" class="hidden bg-surface border border-surface-border rounded-xl px-4 py-3 flex items-center gap-4">
        <div class="text-center">
          <p class="text-gold text-xs font-mono uppercase tracking-widest mb-1">Lines (bottom→top)</p>
          <div class="flex gap-2">
            {["G","B","D","F","A"].map((n,i) => (
              <div class="text-center">
                <div class="w-7 h-7 rounded-full border border-gold/30 flex items-center justify-center">
                  <span class="font-display text-sm text-ivory/80">{n}</span>
                </div>
                <span class="text-ivory/25 text-xs">{i+1}</span>
              </div>
            ))}
          </div>
          <p class="text-ivory/30 text-xs mt-1 italic">"Good Boys Do Fine Always"</p>
        </div>
        <div class="w-px self-stretch bg-surface-border"></div>
        <div class="text-center">
          <p class="text-gold text-xs font-mono uppercase tracking-widest mb-1">Spaces</p>
          <div class="flex gap-2">
            {["A","C","E","G"].map(n => (
              <div class="w-7 h-7 rounded-full border border-gold/30 flex items-center justify-center">
                <span class="font-display text-sm text-ivory/80">{n}</span>
              </div>
            ))}
          </div>
          <p class="text-ivory/30 text-xs mt-1 italic">"All Cows Eat Grass"</p>
        </div>
      </div>
    </div>
  </div>

  <!-- LIVE STAFF
       Architecture:
       • #staff-vf-layer  — VexFlow SVG div (staff lines + clef), never scrolls
       • #staff-notes-canvas — our canvas for noteheads, scrolls left
       Both are absolutely positioned inside #staff-wrap.
  -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-4">
    <div class="bg-surface border border-surface-border rounded-xl overflow-hidden">
      <div class="flex items-center justify-between px-4 pt-3 pb-1">
        <p class="text-ivory/30 text-xs font-mono">Play keys below — notes appear here</p>
        <div class="flex items-center gap-3">
          <p class="text-ivory/20 text-xs font-mono" id="note-count">0 notes</p>
          <div id="playing-indicator" class="w-2 h-2 rounded-full bg-surface-border transition-colors duration-100"></div>
        </div>
      </div>
      <div id="staff-wrap" class="relative" style="height:200px; overflow:hidden;">
        <!-- Layer 1: VexFlow staff + clef (frozen, full width) -->
        <div id="staff-vf-layer"
          class="absolute top-0 left-0 w-full h-full pointer-events-none"
          style="z-index:1;"></div>
        <!-- Layer 2: custom canvas for noteheads (scrolls left) -->
        <canvas id="staff-notes-canvas"
          class="absolute top-0 left-0 pointer-events-none"
          style="height:200px; z-index:2;"></canvas>
      </div>
    </div>
  </div>

  <!-- PIANO -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-4">
    <div class="bg-surface border border-surface-border rounded-xl overflow-hidden">
      <div class="px-4 pt-3 pb-1 flex items-center justify-between flex-wrap gap-2">
        <p class="text-ivory/25 text-xs font-mono">A S D F G H J = white &nbsp;|&nbsp; W E T Y U = black &nbsp;|&nbsp; Swipe for more notes</p>
        <div class="flex items-center gap-2 flex-shrink-0">
          <button id="oct-down" class="w-7 h-7 rounded border border-surface-border text-ivory/50 hover:text-gold text-sm flex items-center justify-center transition-colors">−</button>
          <span class="text-ivory/50 text-xs font-mono">Oct <span id="oct-label">4</span></span>
          <button id="oct-up"   class="w-7 h-7 rounded border border-surface-border text-ivory/50 hover:text-gold text-sm flex items-center justify-center transition-colors">+</button>
        </div>
      </div>
      <div id="piano-keys" class="relative h-36 sm:h-44 px-3 pb-3 select-none"
        style="overflow-x:auto;overflow-y:hidden;touch-action:pan-x;">
        <div id="piano-inner" class="relative h-full"></div>
      </div>
    </div>
  </div>

  <!-- QUIZ — VexFlow draws clef + staff, our canvas draws the notehead -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-4">
    <div class="bg-surface border border-surface-border rounded-xl p-5 space-y-4">
      <div class="flex items-center justify-between flex-wrap gap-2">
        <div>
          <p class="text-gold text-xs tracking-[0.2em] uppercase font-mono mb-0.5">Note quiz</p>
          <p class="text-ivory/60 text-sm">Find this note on the piano. Alternates treble &amp; bass.</p>
        </div>
        <button id="quiz-next" class="text-sm bg-gold hover:bg-gold-dark text-ebony font-medium px-4 py-2 rounded-lg transition-colors">
          New note →
        </button>
      </div>
      <div class="grid sm:grid-cols-2 gap-4 items-center">
        <!-- Quiz staff: VexFlow layer + canvas notehead layer -->
        <div class="relative rounded-lg border border-surface-border overflow-hidden"
          id="quiz-wrap" style="height:160px; background:#141414;">
          <div id="quiz-vf-layer"  class="absolute top-0 left-0 w-full h-full pointer-events-none" style="z-index:1;"></div>
          <canvas id="quiz-canvas" class="absolute top-0 left-0 pointer-events-none" style="z-index:2;"></canvas>
        </div>
        <div class="space-y-3">
          <p class="text-ivory/50 text-sm">Play this note on the piano:</p>
          <div id="quiz-status"
            class="text-center py-3 rounded-lg border border-surface-border bg-surface-raised min-h-[60px] flex items-center justify-center">
            <p class="font-display text-2xl text-ivory/40 italic">Waiting…</p>
          </div>
          <p id="quiz-clef-label" class="text-xs font-mono text-ivory/30 text-center"></p>
          <div class="flex items-center gap-3 text-xs font-mono text-ivory/30">
            <span>✓ <span id="quiz-correct" class="text-green-400">0</span></span>
            <span>✗ <span id="quiz-wrong"   class="text-red-400">0</span></span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- TIPS -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-4 pb-8">
    <div class="bg-surface border border-surface-border rounded-xl p-5">
      <p class="text-gold text-xs tracking-[0.2em] uppercase font-mono mb-4">Tips for reading music</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          { icon:"🎯", title:"Start with landmarks",  tip:"Learn Middle C, Treble G (2nd line), and Bass F (4th line) first. All other notes are found by counting from these anchors." },
          { icon:"📏", title:"Lines vs spaces",       tip:"Notes sit ON a line (line goes through the notehead) or IN a space (between two lines)." },
          { icon:"🔑", title:"The clef is your key",  tip:"Treble clef curls around the G line. Bass clef's dots surround the F line." },
          { icon:"🔢", title:"Count by steps",        tip:"Notes move alphabetically A–G then repeat. Each step up on the staff = one letter up." },
          { icon:"🪄", title:"Ledger lines",          tip:"Middle C sits on a short ledger line below treble clef or above bass clef — the bridge between both." },
          { icon:"🔄", title:"Practice daily",        tip:"5 minutes a day identifying notes builds muscle memory faster than an hour once a week." },
        ].map(item => (
          <div class="flex gap-3">
            <span class="text-xl flex-shrink-0 mt-0.5">{item.icon}</span>
            <div>
              <p class="font-display text-ivory/80 text-sm font-semibold mb-1">{item.title}</p>
              <p class="text-ivory/45 text-xs leading-relaxed">{item.tip}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
    <div class="mt-4">
      <CoffeeButton variant="inline" message="Enjoying the free learning tools? A coffee helps keep them free for everyone." />
    </div>
  </div>

  <!-- ════════════════════════ SCRIPT ════════════════════════════════════════ -->
  <script>
  // Wait for VexFlow to load from CDN
  window.addEventListener('load', function() {
  (function () {

    const VF = Vex.Flow;

    // ── Note utilities ───────────────────────────────────────────────────────
    const NOTE_NAMES = ["C","C#","D","D#","E","F","F#","G","G#","A","A#","B"];
    const DIATONIC   = ["C","D","E","F","G","A","B"];
    const A4 = 440;

    function noteFreq(name, oct) {
      return A4 * Math.pow(2, (NOTE_NAMES.indexOf(name) - 9 + (oct - 4) * 12) / 12);
    }
    function isNatural(n) { return !n.includes("#"); }

    // Diatonic step position relative to C4 = 0
    function diatonicPos(noteName, octave) {
      const b = DIATONIC.indexOf(noteName.replace("#","").replace("b",""));
      return b === -1 ? null : (octave - 4) * 7 + b;
    }

    // VexFlow note key format: "c/4", "d#/5", etc.
    function toVFKey(noteName, octave) {
      return noteName.toLowerCase().replace("#","#") + "/" + octave;
    }

    // ── State ────────────────────────────────────────────────────────────────
    let clef = "treble", showLabels = true, showLandmarks = true;
    let noteHistory = [], octaveBase = 4;
    let audioCtx = null, recDest = null, mediaRec = null;
    let recChunks = [], isRecording = false, recSeconds = 0, recInterval = null;
    let quizNote = null, quizUseClef = "treble";
    let quizCorrect = 0, quizWrong = 0, quizAnswered = false;

    // ── DOM ──────────────────────────────────────────────────────────────────
    const staffWrap    = document.getElementById("staff-wrap");
    const staffVFLayer = document.getElementById("staff-vf-layer");
    const notesCanvas  = document.getElementById("staff-notes-canvas");
    const quizWrap     = document.getElementById("quiz-wrap");
    const quizVFLayer  = document.getElementById("quiz-vf-layer");
    const quizCanvas   = document.getElementById("quiz-canvas");
    const pianoOuter   = document.getElementById("piano-keys");
    const pianoInner   = document.getElementById("piano-inner");
    const noteCountEl  = document.getElementById("note-count");
    const playingInd   = document.getElementById("playing-indicator");
    const clearBtn     = document.getElementById("clear-btn");
    const recBtn       = document.getElementById("rec-btn");
    const recLabel     = document.getElementById("rec-label");
    const recTimerEl   = document.getElementById("rec-timer");
    const recDownload  = document.getElementById("rec-download");
    const quizStatus   = document.getElementById("quiz-status");
    const quizNextBtn  = document.getElementById("quiz-next");
    const quizClefLbl  = document.getElementById("quiz-clef-label");
    const showLabelsEl = document.getElementById("show-labels");
    const showLandEl   = document.getElementById("show-landmarks");
    const legendTreble = document.getElementById("legend-treble");
    const legendBass   = document.getElementById("legend-bass");
    const octLabel     = document.getElementById("oct-label");

    const notesCtx = notesCanvas.getContext("2d");
    const quizCtx  = quizCanvas.getContext("2d");

    // ── Colors ───────────────────────────────────────────────────────────────
    const COL = {
      bg:       "#141414",
      noteFill: "#F8F5EE",
      noteGold: "#C9A84C",
      noteAcc:  "#7CB9E8",
      ledger:   "rgba(248,245,238,0.5)",
      divider:  "rgba(201,168,76,0.4)",
    };

    // ── Staff geometry (matches VexFlow internal layout) ─────────────────────
    // VexFlow draws a stave with 4 spaces × 10px = 40px staff height by default
    // We use scale factor to match our canvas pixel coordinates.
    // Key insight: VexFlow Stave(x, y, width) puts top line at y,
    // with each space = 10px. Middle of staff = y + 20px (top + 2 spaces).

    // We use VexFlow for: staff lines + clef symbol only.
    // We draw noteheads ourselves on the canvas layer so we can:
    //   - control color (gold for landmarks)
    //   - show note name labels
    //   - scroll smoothly without re-rendering VexFlow

    const STAFF_TOP_Y   = 40;   // pixels from canvas top to top staff line
    const SPACE_H       = 10;   // pixels per space (VexFlow default)
    const STAFF_H       = 40;   // 4 spaces × 10px
    // Canvas height:
    const CANVAS_H      = 200;
    // The staff vertical centre (3rd line from bottom = line index 2):
    // Lines from top: 0,10,20,30,40 → centre = 20
    const STAFF_CENTRE_Y = STAFF_TOP_Y + 20;

    // Convert diatonic position (relative to C4=0) → canvas Y
    // Treble: E4 is bottom line (line 1 = y + 40)
    //         G4 is line 2     (y + 30)
    //         B4 is line 3/mid (y + 20) → diatonic pos from C4: B4 = pos 6
    //         D5 is line 4     (y + 10)
    //         F5 is line 5/top (y + 0)   diatonic pos from C4: F5 = pos 10
    // So: Y = STAFF_TOP_Y + (topLinePos - dp) * (SPACE_H/2)
    //   where topLinePos = 10 for treble (F5), 10 for bass... need per-clef.

    function getClefTopPos(forClef) {
      // diatonic pos of the TOP staff line
      if (forClef === "treble") return 10;  // F5
      return -2;                             // A3
    }

    function dpToY(dp, forClef, staffTopY = STAFF_TOP_Y) {
      return staffTopY + (getClefTopPos(forClef) - dp) * (SPACE_H / 2);
    }
    // Compute a sensible staffTopY given a canvas height (centres the staff)
    function centredStaffTop(canvasH) {
      return Math.round((canvasH - STAFF_H) / 2);
    }

    // Lines for each clef (diatonic positions)
    const TREBLE_LINES  = [2, 4, 6, 8, 10]; // E4 G4 B4 D5 F5
    const BASS_LINES    = [-10,-8,-6,-4,-2]; // G2 B2 D3 F3 A3
    const TREBLE_LANDMARKS = [0, 4];  // Middle C, G4
    const BASS_LANDMARKS   = [0,-4];  // Middle C, F3

    // ── VexFlow staff renderer ───────────────────────────────────────────────
    // CLEF_ZONE: pixels reserved for clef before notes start
    const CLEF_ZONE      = 70;
    const NOTE_START_X   = CLEF_ZONE + 10;
    const NOTE_SPACING   = 38;

    let vfRenderer = null;

    function buildVFStaff(containerEl, w, h, forClef, staffTopY) {
      // Clear previous VexFlow SVG
      containerEl.innerHTML = "";

      const renderer = new VF.Renderer(containerEl, VF.Renderer.Backends.SVG);
      renderer.resize(w, h);
      const ctx = renderer.getContext();

      // Style the SVG to match our dark theme
      const svg = containerEl.querySelector("svg");
      if (svg) {
        svg.style.position   = "absolute";
        svg.style.top        = "0";
        svg.style.left       = "0";
        svg.style.background = "transparent";
      }

      // Draw a stave across the full width
      // Stave(x, y, width) — y is the TOP of the top staff line
      const stave = new VF.Stave(0, staffTopY, w - 4);
      stave.addClef(forClef);

      // Style: white-ish lines to match our theme
      ctx.setStrokeStyle("rgba(248,245,238,0.28)");
      ctx.setFillStyle("#C9A84C");   // clef colour = gold

      stave.setContext(ctx).draw();

      // Re-colour the clef glyph gold (VexFlow draws it in black by default)
      // Find all path/text elements after the staff lines and tint them
      if (svg) {
        // Staff lines are <path> or <line>; clef is usually last rendered
        // Apply gold fill to everything VexFlow drew
        const paths = svg.querySelectorAll("path, rect, text");
        paths.forEach(el => {
          el.style.fill   = "#C9A84C";
          el.style.stroke = "#C9A84C";
        });
        // Lines specifically should be ivory, not gold
        const lines = svg.querySelectorAll("line");
        lines.forEach(el => {
          el.style.stroke = "rgba(248,245,238,0.28)";
          el.style.fill   = "none";
        });
      }

      return stave;
    }

    // ── Resize + full rebuild ────────────────────────────────────────────────
    function resizeAndDraw() {
      const w = staffWrap.clientWidth;

      // Main staff VF layer
      const sty = centredStaffTop(CANVAS_H); buildVFStaff(staffVFLayer, w, CANVAS_H, clef, sty);

      // Draw divider line on VF layer after a tick (let VF render first)
      setTimeout(() => drawDivider(staffVFLayer, CANVAS_H, centredStaffTop(CANVAS_H)), 30);

      // Notes canvas
      notesCanvas.height = CANVAS_H;
      redrawNotes();

      // Quiz
      rebuildQuizVF();
    }

    function drawDivider(containerEl, h, staffTopY = STAFF_TOP_Y) {
      // Add a gold vertical line at CLEF_ZONE using an SVG line
      const svg = containerEl.querySelector("svg");
      if (!svg) return;
      // Remove any existing divider
      const old = svg.querySelector(".clef-divider");
      if (old) old.remove();
      const ns   = "http://www.w3.org/2000/svg";
      const line = document.createElementNS(ns, "line");
      line.setAttribute("class", "clef-divider");
      line.setAttribute("x1", CLEF_ZONE);
      line.setAttribute("y1", STAFF_TOP_Y - 4);
      line.setAttribute("x2", CLEF_ZONE);
      line.setAttribute("y2", STAFF_TOP_Y + STAFF_H + 4);
      line.setAttribute("stroke", "rgba(201,168,76,0.45)");
      line.setAttribute("stroke-width", "1");
      svg.appendChild(line);
    }

    // ── Redraw notes canvas ──────────────────────────────────────────────────
    function redrawNotes() {
      const needed = NOTE_START_X + noteHistory.length * NOTE_SPACING + 60;
      notesCanvas.width = Math.max(staffWrap.clientWidth, needed);
      notesCtx.clearRect(0, 0, notesCanvas.width, CANVAS_H);

      // Clip region: notes only right of CLEF_ZONE
      notesCtx.save();
      notesCtx.beginPath();
      notesCtx.rect(CLEF_ZONE + 2, 0, notesCanvas.width, CANVAS_H);
      notesCtx.clip();

      const lines    = clef === "treble" ? TREBLE_LINES    : BASS_LINES;
      const landmarks = clef === "treble" ? TREBLE_LANDMARKS : BASS_LANDMARKS;
      const bottomLine = Math.min(...lines);
      const topLine    = Math.max(...lines);

      const mainSty = centredStaffTop(CANVAS_H);
      noteHistory.forEach((entry, i) => {
        const x  = NOTE_START_X + i * NOTE_SPACING;
        const dp = diatonicPos(entry.noteName.replace("#",""), entry.octave);
        if (dp !== null) {
          drawNotehead(notesCtx, x, dp, clef, lines, bottomLine, topLine, landmarks,
            entry.noteName, entry.octave, i === noteHistory.length - 1, mainSty);
        }
      });

      notesCtx.restore();

      noteCountEl.textContent = `${noteHistory.length} note${noteHistory.length !== 1 ? "s" : ""}`;
      scrollToLatest();
    }

    function scrollToLatest() {
      if (noteHistory.length === 0) return;
      const latestX  = NOTE_START_X + (noteHistory.length - 1) * NOTE_SPACING;
      const viewW    = staffWrap.clientWidth;
      const overflow = latestX - viewW + 80;
      notesCanvas.style.transform = overflow > 0 ? `translateX(-${overflow}px)` : "";
    }

    // ── Draw a single notehead ───────────────────────────────────────────────
    function drawNotehead(ctx, x, dp, forClef, lines, bottomLine, topLine, landmarks,
                          noteName, octave, isActive, staffTopY = STAFF_TOP_Y) {
      const y          = dpToY(dp, forClef, staffTopY);
      const r          = SPACE_H * 0.45;   // notehead radius ≈ half a space
      const isLandmark = showLandmarks && landmarks.includes(dp);
      const isAccid    = !isNatural(noteName);

      // Ledger lines
      ctx.strokeStyle = COL.ledger;
      ctx.lineWidth   = 1.2;
      const lp = dp % 2 === 0 ? 0 : 0;
      // Below staff
      for (let p = bottomLine - 2; p >= dp; p -= 2) {
        const ly = dpToY(p, forClef, staffTopY);
        ctx.beginPath();
        ctx.moveTo(x - r * 1.8, ly); ctx.lineTo(x + r * 1.8, ly);
        ctx.stroke();
      }
      // Above staff
      for (let p = topLine + 2; p <= dp; p += 2) {
        const ly = dpToY(p, forClef, staffTopY);
        ctx.beginPath();
        ctx.moveTo(x - r * 1.8, ly); ctx.lineTo(x + r * 1.8, ly);
        ctx.stroke();
      }

      // Notehead fill
      const fill = isActive   ? "#FFFFFF" :
                   isLandmark ? COL.noteGold :
                   isAccid    ? COL.noteAcc  : COL.noteFill;

      ctx.beginPath();
      ctx.ellipse(x, y, r * 1.25, r * 0.88, -0.15, 0, Math.PI * 2);
      ctx.fillStyle = fill;
      ctx.fill();

      // Stem — direction: below middle line → stem up, above → stem down
      const midLinePos = lines[Math.floor(lines.length / 2)];
      const stemDir    = dp < midLinePos ? 1 : -1;
      ctx.strokeStyle = fill;
      ctx.lineWidth   = 1.5;
      const stemX     = x + (stemDir === -1 ? r * 1.2 : -r * 1.2);
      ctx.beginPath();
      ctx.moveTo(stemX, y);
      ctx.lineTo(stemX, y + stemDir * SPACE_H * 3.5);
      ctx.stroke();

      // Sharp sign
      if (isAccid) {
        ctx.fillStyle = COL.noteAcc;
        ctx.font      = `bold ${r * 2.2}px sans-serif`;
        ctx.textAlign = "center";
        ctx.fillText("#", x - r * 2.4, y + r * 0.5);
      }

      // Note name label
      if (showLabels) {
        ctx.fillStyle = isLandmark ? COL.noteGold : "rgba(201,168,76,0.7)";
        ctx.font      = `500 ${r * 2}px 'DM Sans', sans-serif`;
        ctx.textAlign = "center";
        ctx.fillText(noteName.replace("#",""), x, y + r + SPACE_H * 1.4);
      }

      // Octave hint (very faint)
      ctx.fillStyle = "rgba(248,245,238,0.1)";
      ctx.font      = `${r * 1.5}px monospace`;
      ctx.textAlign = "center";
      ctx.fillText(octave, x, y - SPACE_H * 3.2);
    }

    function addNote(noteName, octave) {
      noteHistory.push({ noteName, octave });
      redrawNotes();
    }

    // ── Audio ────────────────────────────────────────────────────────────────
    function getCtx() {
      if (!audioCtx) {
        audioCtx = new AudioContext();
        recDest  = audioCtx.createMediaStreamDestination();
      }
      if (audioCtx.state === "suspended") audioCtx.resume();
      return audioCtx;
    }

    function playAndNotate(noteName, octave) {
      const ctx  = getCtx();
      const osc  = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.type = "triangle";
      osc.frequency.value = noteFreq(noteName, octave);
      gain.gain.setValueAtTime(0.4, ctx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 1.2);
      osc.connect(gain);
      gain.connect(ctx.destination);
      if (recDest) gain.connect(recDest);
      osc.start(); osc.stop(ctx.currentTime + 1.3);
      addNote(noteName, octave);
      playingInd.style.background = "#C9A84C";
      setTimeout(() => { playingInd.style.background = ""; }, 150);
      checkQuizAnswer(noteName, octave);
    }

    // ── Piano keyboard ────────────────────────────────────────────────────────
    const WHITE_SEMI = [0,2,4,5,7,9,11];
    const BLACK_SEMI = [1,3,-1,6,8,10,-1];
    const OCTAVES = 4, KEY_W = 36;

    function buildPianoKeys() {
      pianoInner.innerHTML = "";
      const whites = [];
      for (let o = 0; o < OCTAVES; o++) {
        WHITE_SEMI.forEach(s => whites.push({
          freq:   noteFreq(NOTE_NAMES[s], octaveBase - 1 + o),
          name:   NOTE_NAMES[s],
          octave: octaveBase - 1 + o,
        }));
      }
      pianoInner.style.width  = whites.length * (KEY_W + 1) + "px";
      pianoInner.style.height = "100%";

      whites.forEach((k, i) => {
        const el = document.createElement("div");
        el.className = "piano-key white-key absolute bottom-0 rounded-b-md border border-gray-700 cursor-pointer transition-colors duration-75 bg-ivory hover:bg-gold/20 flex items-end justify-center pb-1";
        el.style.cssText = `width:${KEY_W}px;left:${i*(KEY_W+1)}px;top:0;bottom:0;`;
        el.innerHTML = `<span style="font-size:8px" class="text-ebony/20 font-mono pointer-events-none select-none">${k.name}${k.octave}</span>`;
        el.dataset.freq = k.freq; el.dataset.note = k.name; el.dataset.octave = k.octave;
        pianoInner.appendChild(el);
      });

      for (let o = 0; o < OCTAVES; o++) {
        BLACK_SEMI.forEach((s, wi) => {
          if (s === -1) return;
          const el = document.createElement("div");
          el.className = "piano-key black-key absolute rounded-b-md z-10 cursor-pointer transition-colors duration-75 bg-ebony hover:bg-gray-700";
          el.style.cssText = `width:${KEY_W*0.6}px;left:${(o*7+wi)*(KEY_W+1)+KEY_W*0.7}px;top:0;height:60%;box-shadow:0 4px 8px rgba(0,0,0,.8);`;
          el.dataset.freq = noteFreq(NOTE_NAMES[s], octaveBase-1+o);
          el.dataset.note = NOTE_NAMES[s];
          el.dataset.octave = octaveBase - 1 + o;
          pianoInner.appendChild(el);
        });
      }

      pianoOuter.scrollLeft = 7 * (KEY_W + 1) - 20;
      attachPianoEvents();
    }

    function attachPianoEvents() {
      let lastEl = null;

      function getKeyAt(x, y) {
        const rect = pianoOuter.getBoundingClientRect();
        const rx   = x - rect.left + pianoOuter.scrollLeft;
        const ry   = y - rect.top;
        for (const k of pianoInner.querySelectorAll(".black-key")) {
          const kl = parseFloat(k.style.left), kw = parseFloat(k.style.width);
          if (rx >= kl && rx <= kl + kw && ry <= pianoInner.clientHeight * 0.6) return k;
        }
        for (const k of pianoInner.querySelectorAll(".white-key")) {
          const kl = parseFloat(k.style.left);
          if (rx >= kl && rx <= kl + KEY_W) return k;
        }
        return null;
      }

      function trigger(el) {
        if (!el || el === lastEl) return;
        lastEl = el;
        playAndNotate(el.dataset.note, parseInt(el.dataset.octave));
        el.classList.add("active");
        setTimeout(() => el.classList.remove("active"), 200);
      }

      pianoInner.querySelectorAll("[data-note]").forEach(el => {
        el.addEventListener("mousedown",  e => { e.preventDefault(); trigger(el); });
        el.addEventListener("touchstart", e => { e.preventDefault(); trigger(el); }, { passive:false });
      });

      pianoOuter.addEventListener("mousemove", e => {
        if (e.buttons !== 1) { lastEl = null; return; }
        trigger(getKeyAt(e.clientX, e.clientY));
      });
      pianoOuter.addEventListener("mouseup",    () => lastEl = null);
      pianoOuter.addEventListener("mouseleave", () => lastEl = null);
      pianoOuter.addEventListener("touchmove",  e => {
        Array.from(e.changedTouches).forEach(t => {
          const el = getKeyAt(t.clientX, t.clientY);
          if (el) trigger(el);
        });
      });
      pianoOuter.addEventListener("touchend", () => lastEl = null);
    }

    const KB = {"a":"C","w":"C#","s":"D","e":"D#","d":"E","f":"F","t":"F#","g":"G","y":"G#","h":"A","u":"A#","j":"B"};
    document.addEventListener("keydown", e => {
      if (e.target instanceof HTMLInputElement || e.repeat) return;
      const k = e.key.toLowerCase();
      if (KB[k]) {
        playAndNotate(KB[k], octaveBase);
        pianoInner.querySelectorAll("[data-note]").forEach(el => {
          if (el.dataset.note === KB[k] && parseInt(el.dataset.octave) === octaveBase) {
            el.classList.add("active");
            setTimeout(() => el.classList.remove("active"), 200);
          }
        });
      }
    });

    document.getElementById("oct-down").addEventListener("click", () => {
      if (octaveBase > 2) { octaveBase--; octLabel.textContent = octaveBase; buildPianoKeys(); }
    });
    document.getElementById("oct-up").addEventListener("click", () => {
      if (octaveBase < 6) { octaveBase++; octLabel.textContent = octaveBase; buildPianoKeys(); }
    });

    // ── Quiz ─────────────────────────────────────────────────────────────────
    const QUIZ_TREBLE = [
      {n:"C",o:4},{n:"D",o:4},{n:"E",o:4},{n:"F",o:4},{n:"G",o:4},
      {n:"A",o:4},{n:"B",o:4},{n:"C",o:5},{n:"D",o:5},{n:"E",o:5},
    ];
    const QUIZ_BASS = [
      {n:"G",o:2},{n:"A",o:2},{n:"B",o:2},{n:"C",o:3},{n:"D",o:3},
      {n:"E",o:3},{n:"F",o:3},{n:"G",o:3},{n:"A",o:3},{n:"B",o:3},
    ];

    const QUIZ_H         = 160;
    const QUIZ_VF_W      = 280;
    const QUIZ_CLEF_ZONE = 65;

    function getQuizSty() { return centredStaffTop(QUIZ_H); }

    function rebuildQuizVF() {
      const qSty = getQuizSty();
      buildVFStaff(quizVFLayer, QUIZ_VF_W, QUIZ_H, quizUseClef, qSty);
      setTimeout(() => drawDivider(quizVFLayer, QUIZ_H, qSty), 30);
      quizCanvas.width  = QUIZ_VF_W;
      quizCanvas.height = QUIZ_H;
      drawQuizNote();
    }

    function newQuizNote() {
      quizUseClef  = quizUseClef === "treble" ? "bass" : "treble";
      const pool   = quizUseClef === "treble" ? QUIZ_TREBLE : QUIZ_BASS;
      quizNote     = pool[Math.floor(Math.random() * pool.length)];
      quizAnswered = false;
      quizStatus.innerHTML = `<p class="font-display text-2xl text-ivory/40 italic">Waiting…</p>`;
      quizClefLbl.textContent = quizUseClef === "treble" ? "𝄞 Treble clef" : "𝄢 Bass clef";
      rebuildQuizVF();
    }

    function drawQuizNote() {
      quizCtx.clearRect(0, 0, QUIZ_VF_W, QUIZ_H);
      if (!quizNote) return;

      const lines     = quizUseClef === "treble" ? TREBLE_LINES    : BASS_LINES;
      const landmarks = quizUseClef === "treble" ? TREBLE_LANDMARKS : BASS_LANDMARKS;
      const bottomLine = Math.min(...lines);
      const topLine    = Math.max(...lines);
      const dp         = diatonicPos(quizNote.n, quizNote.o);
      if (dp === null) return;

      // Clip to right of divider
      quizCtx.save();
      quizCtx.beginPath();
      quizCtx.rect(QUIZ_CLEF_ZONE + 2, 0, QUIZ_VF_W, QUIZ_H);
      quizCtx.clip();

      const qSty = getQuizSty();
      drawNotehead(quizCtx, QUIZ_VF_W / 2 + 10, dp, quizUseClef,
        lines, bottomLine, topLine, landmarks,
        quizNote.n, quizNote.o, false, qSty);

      // If labels hidden, erase the label so quiz is harder
      if (!showLabels) {
        const ny = dpToY(dp, quizUseClef, qSty);
        quizCtx.fillStyle = COL.bg;
        quizCtx.fillRect(QUIZ_VF_W/2 - 5, ny + 8, 50, 20);
      }
      quizCtx.restore();
    }

    function checkQuizAnswer(noteName, octave) {
      if (!quizNote || quizAnswered) return;
      if (noteName.replace("#","") === quizNote.n && octave === quizNote.o) {
        quizAnswered = true; quizCorrect++;
        document.getElementById("quiz-correct").textContent = quizCorrect;
        quizStatus.innerHTML = `<p class="font-display text-2xl text-green-400">✓ ${quizNote.n}${quizNote.o}!</p>`;
        setTimeout(newQuizNote, 1800);
      } else if (isNatural(noteName)) {
        quizWrong++;
        document.getElementById("quiz-wrong").textContent = quizWrong;
        quizStatus.innerHTML = `<p class="font-display text-lg text-red-400">Not quite — look at the staff!</p>`;
      }
    }

    // ── Recorder ─────────────────────────────────────────────────────────────
    recBtn.addEventListener("click", () => {
      if (isRecording) {
        mediaRec.stop(); isRecording = false;
        recLabel.textContent = "Record";
        recBtn.classList.remove("border-red-500/50","text-red-400");
        clearInterval(recInterval);
      } else {
        getCtx();
        mediaRec = new MediaRecorder(recDest.stream); recChunks = [];
        mediaRec.ondataavailable = e => { if(e.data.size>0) recChunks.push(e.data); };
        mediaRec.onstop = () => {
          recDownload.href = URL.createObjectURL(new Blob(recChunks,{type:"audio/webm"}));
          recDownload.classList.remove("hidden");
        };
        mediaRec.start(100); isRecording = true; recSeconds = 0;
        recLabel.textContent = "Stop";
        recBtn.classList.add("border-red-500/50","text-red-400");
        recDownload.classList.add("hidden");
        recInterval = setInterval(() => {
          recSeconds++;
          recTimerEl.textContent = `${Math.floor(recSeconds/60)}:${String(recSeconds%60).padStart(2,"0")}`;
        }, 1000);
      }
    });

    // ── Controls ─────────────────────────────────────────────────────────────
    document.querySelectorAll(".clef-btn").forEach(btn => {
      btn.addEventListener("click", () => {
        clef = btn.dataset.clef;
        document.querySelectorAll(".clef-btn").forEach(b => {
          const a = b === btn;
          b.classList.toggle("bg-gold",a); b.classList.toggle("text-ebony",a);
          b.classList.toggle("text-ivory/50",!a);
        });
        legendTreble.classList.toggle("hidden", clef !== "treble");
        legendBass.classList.toggle("hidden",   clef !== "bass");
        resizeAndDraw();
      });
    });

    showLabelsEl.addEventListener("change", e => {
      showLabels = e.target.checked; redrawNotes(); drawQuizNote();
    });
    showLandEl.addEventListener("change", e => {
      showLandmarks = e.target.checked; redrawNotes();
    });
    clearBtn.addEventListener("click", () => {
      noteHistory = [];
      notesCanvas.style.transform = "";
      redrawNotes();
    });
    quizNextBtn.addEventListener("click", newQuizNote);

    // ── Init ─────────────────────────────────────────────────────────────────
    window.addEventListener("resize", resizeAndDraw);
    resizeAndDraw();
    buildPianoKeys();
    newQuizNote();

  })();
  }); // end window.onload
  </script>

  <style>
    .white-key.active { background: rgba(201,168,76,0.4) !important; }
    .black-key.active { background: rgba(201,168,76,0.7) !important; }
    /* Make VexFlow SVG transparent bg so our dark surface shows through */
    #staff-vf-layer svg,
    #quiz-vf-layer  svg { background: transparent !important; }
  </style>

</Layout>
